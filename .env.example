# ============================================
# DOCTOR8 — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values
# NEVER commit .env to GitHub
# ============================================

# APP — public HTTPS URL (required in production for emails, Lacuna signing, redirects)
# Production: https://app.doctor8.org — NEVER use localhost in deployed environments
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Doctor8
APP_REGION=US   # US or EU — controls data residency
# Video calls use DAILY_API_KEY (see DEPLOY.md). Cloud recording is OFF by default.
# DAILY_CLOUD_RECORDING=1   # OPTIONAL — ~$0.013/min extra on your Daily bill; enable only after cost review
# DAILY_WEBHOOK_SECRET=...  # Only if recording enabled — HMAC from POST /webhooks create response

# DATABASE (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/doctor8

# AUTH SECRET (generate with: openssl rand -base64 32)
AUTH_SECRET=your-super-secret-key-here-change-this

# GOOGLE OAUTH (optional for social login)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GOOGLE MEET — humanitarian handoff (Calendar API + domain-wide delegation)
# GOOGLE_MEET_ENABLED=1
# GOOGLE_CALENDAR_USER=concierge@doctor8.com.br
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}   # full JSON, one line
# GOOGLE_MEET_DEFAULT_URL=   # dev fallback only — omit in production

# DATABASE connection pool (append to DATABASE_URL for multi-instance deploys):
# ?connection_limit=5&pool_timeout=20

# STRIPE — payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# STRIPE PRICES (create in Stripe dashboard — enable card, PIX, boleto for BR)
# Optional: STRIPE_SUBSCRIPTION_PIX=1 to offer PIX on BRL subscriptions (Stripe Pix Automático)
STRIPE_PRICE_CLUB_DOCTOR_US=price_...   # $9.90/month USD
STRIPE_PRICE_CLUB_DOCTOR_EU=price_...   # EUR/month
STRIPE_PRICE_CLUB_DOCTOR_BRL=price_...  # BRL/month (card + PIX + boleto)
STRIPE_PRICE_CLUB_DOCTOR_VE=price_...   # Venezuela USD (optional — falls back to US price)
STRIPE_PRICE_PROFESSIONAL_US=price_...  # Professional monthly USD
STRIPE_PRICE_PROFESSIONAL_EU=price_...
STRIPE_PRICE_PROFESSIONAL_BRL=price_...  # Doctor Connection - BRL/month
STRIPE_PRICE_PROFESSIONAL_VE=price_...   # Venezuela USD (optional — falls back to US price)
# Legacy fallback (optional)
STRIPE_PRICE_CLUB_DOCTOR=price_...
STRIPE_PRICE_PROFESSIONAL=price_...

# AWS S3 — file storage (separate buckets per region)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_US=us-east-1
AWS_REGION_EU=eu-central-1
AWS_S3_BUCKET_US=doctor8-files-us
AWS_S3_BUCKET_EU=doctor8-files-eu

# EMAIL — Resend
RESEND_API_KEY=re_...
# Use display name + verified domain (improves deliverability)
EMAIL_FROM=Doctor8 <noreply@doctor8.org>
# Reply-to for transactional mail (reduces spam score vs noreply-only)
EMAIL_REPLY_TO=support@doctor8.org
# SOS Venezuela — coordination inbox for triage/anamnesis alerts (comma-separated)
HUMANITARIAN_COORDINATION_EMAIL=coordenacion@acurabrasil.org
# Admin inbox when a provider uploads CRM/CRP documents (comma-separated; falls back to HUMANITARIAN_COORDINATION_EMAIL)
PROVIDER_VERIFICATION_NOTIFY_EMAIL=controladoria@doctor8.com.br

# ENCRYPTION — for PHI fields at rest (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your-32-byte-hex-key-here

# LACUNA REST PKI CORE — digital signature with cloud certificates (BirdID/VIDaaS)
# Request access at https://core.pki.rest (SaaS) and create an Application (role
# "Operador"/Worker), then a Key. The full key value (incl. the "app|" prefix) is
# what goes in LACUNA_API_KEY.
LACUNA_ENDPOINT=https://core.pki.rest
LACUNA_API_KEY=
# Free ITI test security context for development (sign without a real certificate).
# For production with real Vidaas/BirdID certificates, leave empty or use Lacuna's ICP-Brasil context.
# Using the test GUID below with real Vidaas certs can cause OAuth errors on certificado.vidaas.com.br.
LACUNA_SECURITY_CONTEXT=803517ad-3bbc-4169-b085-60053a8f6dbf

# SESSION
# HIPAA requires session timeout — 15 minutes of inactivity
SESSION_MAX_AGE_SECONDS=900

# QSTASH — scheduled reminders (email, WhatsApp, review requests)
# QSTASH_TOKEN=
# QSTASH_CURRENT_SIGNING_KEY=
# QSTASH_NEXT_SIGNING_KEY=

# WHATSAPP — Meta Cloud API (app 9bitts / WhatsApp Business)
#
# Until Meta approves your utility templates, leave these empty — the app keeps working
# with wa.me link fallbacks (humanitarian handoff, manual share buttons, email links).
# When approved, set WHATSAPP_ACCESS_TOKEN + WHATSAPP_PHONE_NUMBER_ID on Railway.
#
# Submit templates in Meta Business Manager (utility category):
#   - doctor8_appointment_reminder  (body: name, doctor, date/time)
#   - doctor8_clinical_document     (body: name, doctor, doc type, link)
# Approve each language you need: pt_BR, en_US, es
#
# Permanent token from Meta Business > System users, or temporary from API Setup
WHATSAPP_ACCESS_TOKEN=
# Phone number ID (not the phone itself) — WhatsApp > API Setup
WHATSAPP_PHONE_NUMBER_ID=
# Utility template name approved in Meta Business Manager (default below)
WHATSAPP_REMINDER_TEMPLATE=doctor8_appointment_reminder
# Template for clinical document / prescription delivery (approve in Meta Business Manager)
# WHATSAPP_DOCUMENT_TEMPLATE=doctor8_clinical_document
# WHATSAPP_HUMANITARIAN_TURN_TEMPLATE=doctor8_humanitarian_your_turn
WHATSAPP_TEMPLATE_LANG=pt_BR
WHATSAPP_DEFAULT_COUNTRY_CODE=58
# Venezuela (+58) recommended for humanitarian campaign; Brazil uses 55
# WHATSAPP_GRAPH_API_VERSION=v22.0
# Set to 1 only if your template has a dynamic URL button (index 0)
# WHATSAPP_REMINDER_URL_BUTTON=0
# Webhook URL: https://app.doctor8.org/api/webhooks/whatsapp
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-random-verify-string

# SMART on FHIR — third-party patient apps (public client + PKCE)
# SMART_OAUTH_CLIENT_ID=doctor8-public
# SMART_OAUTH_REDIRECT_URIS=http://localhost:3001/callback,https://your-app.example/callback
# Without SMART_OAUTH_REDIRECT_URIS, localhost callbacks are allowed in development.

# SMS — AWS SNS (recommended; uses credentials above)
# Region for SMS — us-east-1 recommended for international SMS
AWS_SNS_REGION=us-east-1
# Optional sender ID (not supported in all countries, e.g. US/CA block custom sender IDs)
# AWS_SNS_SENDER_ID=Doctor8
SMS_DEFAULT_COUNTRY_CODE=55

# SMS — Twilio (optional fallback if AWS SNS not configured)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=
# TWILIO_SMS_FROM=

# PHARMACY — CMED reference prices (Medicamentos API.br / ANVISA) only
# Reference pricing is on by default; set false to hide the price lookup panel.
# Doctor8 does NOT sell medications — UI has no purchase/checkout (save-to-list is for personal records only).
PHARMACY_REFERENCE_ENABLED=true
MEDICAMENTOS_API_BR_BASE_URL=https://medicamentos.api.br
# Partner marketplace API — backend only; no buy buttons in the app. Keep false unless product policy changes.
PHARMACY_MARKETPLACE_ENABLED=false
PHARMACY_PROVIDER=consulta-remedios
PHARMACY_PARTNER_BASE_URL=https://consultaremedios.com.br
# Affiliate / tracking (fill after partner contract)
PHARMACY_AFFILIATE_ID=
PHARMACY_UTM_SOURCE=doctor8
PHARMACY_UTM_MEDIUM=referral
PHARMACY_UTM_CAMPAIGN=medications
# Full API integration (optional — enables in-app price offers when both are set)
PHARMACY_API_BASE_URL=
PHARMACY_API_KEY=

# ANTHROPIC — clinical AI summaries (document analysis, consult notes)
ANTHROPIC_API_KEY=

# OPENAI — optional, for consult audio transcription (Whisper)
OPENAI_API_KEY=

# COMPLIANCE
HIPAA_MODE=true      # Enables extra HIPAA controls for US users
GDPR_MODE=true       # Enables GDPR controls for EU users
DPO_EMAIL=dpo@doctor8.org   # Data Protection Officer email (GDPR)

# MONITORING (optional — errors only; disabled when unset)
SENTRY_DSN=

# WEB PUSH (optional — browser notifications alongside in-app bell)
# Generate: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=   # same value as VAPID_PUBLIC_KEY for the client
# VAPID_SUBJECT=mailto:support@doctor8.org

# E2E / Playwright (local or CI — optional; auth tests skip when unset locally)
# PLAYWRIGHT_BASE_URL=http://localhost:3000
# Run: npm run seed:e2e && npm run test:e2e
# Defaults for CI (also used when E2E_* unset in CI):
# E2E_PATIENT_EMAIL=e2e-patient@doctor8.test
# E2E_PATIENT_PASSWORD=TestPassword1!
# E2E_PROFESSIONAL_EMAIL=e2e-volunteer@doctor8.test
# E2E_PROFESSIONAL_PASSWORD=TestPassword1!
# E2E_ADMIN_EMAIL=e2e-admin@doctor8.test
# E2E_ADMIN_PASSWORD=TestPassword1!
