# ============================================
# DOCTOR8 — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values
# NEVER commit .env to GitHub
# ============================================

# APP — must be the public HTTPS URL in production (required for Lacuna/Vidaas signing)
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=
NEXT_PUBLIC_APP_NAME=Doctor8
APP_REGION=US   # US or EU — controls data residency

# DATABASE (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/doctor8

# AUTH SECRET (generate with: openssl rand -base64 32)
AUTH_SECRET=your-super-secret-key-here-change-this

# GOOGLE OAUTH (optional for social login)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# STRIPE — payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# STRIPE PRICES (create in Stripe dashboard)
STRIPE_PRICE_CLUB_DOCTOR_US=price_...   # $9.90/month USD
STRIPE_PRICE_CLUB_DOCTOR_EU=price_...   # €9.90/month EUR

# AWS S3 — file storage (separate buckets per region)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_US=us-east-1
AWS_REGION_EU=eu-central-1
AWS_S3_BUCKET_US=doctor8-files-us
AWS_S3_BUCKET_EU=doctor8-files-eu

# EMAIL — Resend
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@doctor8.app

# ENCRYPTION — for PHI fields at rest (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your-32-byte-hex-key-here

# LACUNA REST PKI CORE — digital signature with cloud certificates (BirdID/VIDaaS)
# Request access at https://core.pki.rest (SaaS) and create an Application (role
# "Operador"/Worker), then a Key. The full key value (incl. the "app|" prefix) is
# what goes in LACUNA_API_KEY.
LACUNA_ENDPOINT=https://core.pki.rest
LACUNA_API_KEY=
# Free ITI test security context for development (sign without a real certificate).
# For production with real Vidaas/BirdID certificates, leave empty or use Lacuna's ICP-Brasil context.
# Using the test GUID below with real Vidaas certs can cause OAuth errors on certificado.vidaas.com.br.
LACUNA_SECURITY_CONTEXT=803517ad-3bbc-4169-b085-60053a8f6dbf

# SESSION
# HIPAA requires session timeout — 15 minutes of inactivity
SESSION_MAX_AGE_SECONDS=900

# COMPLIANCE
HIPAA_MODE=true      # Enables extra HIPAA controls for US users
GDPR_MODE=true       # Enables GDPR controls for EU users
DPO_EMAIL=dpo@doctor8.app   # Data Protection Officer email (GDPR)
