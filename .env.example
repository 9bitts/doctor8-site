# ============================================
# DOCTOR8 — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values
# NEVER commit .env to GitHub
# ============================================

# APP — public HTTPS URL (required in production for emails, Lacuna signing, redirects)
# Production: https://app.doctor8.org — NEVER use localhost in deployed environments
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Doctor8
# Google Analytics 4 — public marketing pages only, after cookie consent
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
APP_REGION=US   # US or EU — controls data residency
# Video calls use DAILY_API_KEY (see DEPLOY.md). Cloud recording is OFF by default.
# DAILY_CLOUD_RECORDING=1   # OPTIONAL — ~$0.013/min extra on your Daily bill; enable only after cost review
# DAILY_WEBHOOK_SECRET=...  # Only if recording enabled — HMAC from POST /webhooks create response

# DATABASE (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/doctor8

# AUTH SECRET (generate with: openssl rand -base64 32)
AUTH_SECRET=your-super-secret-key-here-change-this

# GOOGLE OAUTH (optional for social login)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GOOGLE MEET — humanitarian handoff (Calendar API + domain-wide delegation)
# GOOGLE_MEET_ENABLED=1
# GOOGLE_CALENDAR_USER=concierge@doctor8.com.br
# GOOGLE_WORKSPACE_DOMAIN=doctor8.com.br
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}   # full JSON, one line
# GOOGLE_MEET_DEFAULT_URL=   # dev fallback only — omit in production
# Fixed Meet room for professional coordination (recurring Calendar event URL)
# Prefer server-only vars (not exposed to browser bundle):
# MEETING_ROOM_NISE_URL=https://meet.google.com/xxx-xxxx-xxx
# MEETING_ROOM_ALIANCA_PELA_VIDA_URL=https://meet.google.com/knj-ohde-eih
# MEETING_ROOM_DOCTOR8_URL=https://meet.google.com/kbe-vkof-xza
# MEETING_ROOM_MEDICOS_PELA_VIDA_URL=https://meet.google.com/dtp-rdjw-wuz
# MEETING_ROOM_CLAUDIA_URL=https://meet.google.com/pan-xqiv-xor
# Legacy (client-visible fallback — migrate to MEETING_ROOM_* above):
# NEXT_PUBLIC_MEETING_ROOM_NISE_URL=https://meet.google.com/xxx-xxxx-xxx
# (use the full https:// URL — without it the browser treats the link as internal and returns 404)

# DATABASE connection pool (append to DATABASE_URL for multi-instance deploys):
# ?connection_limit=5&pool_timeout=20

# STRIPE — payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_CONNECT_ENABLED=true   # Express onboarding for profit-share payouts (default OFF; no automatic transfers)
# STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...  # Only if Connect uses a separate webhook endpoint (optional; same endpoint uses STRIPE_WEBHOOK_SECRET)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# STRIPE PRICES (create in Stripe dashboard — enable card, PIX, boleto for BR)
# Optional: STRIPE_SUBSCRIPTION_PIX=1 to offer PIX on BRL subscriptions (Stripe Pix Automático)
STRIPE_PRICE_CLUB_DOCTOR_US=price_...   # $9.90/month USD
STRIPE_PRICE_CLUB_DOCTOR_EU=price_...   # EUR/month
STRIPE_PRICE_CLUB_DOCTOR_BRL=price_...  # BRL/month (card + PIX + boleto)
STRIPE_PRICE_CLUB_DOCTOR_VE=price_...   # Venezuela USD (optional — falls back to US price)
STRIPE_PRICE_PROFESSIONAL_US=price_...  # Professional monthly USD
STRIPE_PRICE_PROFESSIONAL_EU=price_...
STRIPE_PRICE_PROFESSIONAL_BRL=price_...  # Doctor Connection - BRL/month
STRIPE_PRICE_PROFESSIONAL_VE=price_...   # Venezuela USD (optional — falls back to US price)
# Legacy fallback (optional)
STRIPE_PRICE_CLUB_DOCTOR=price_...
STRIPE_PRICE_PROFESSIONAL=price_...

# AWS S3 — file storage (separate buckets per region)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_US=us-east-1
AWS_REGION_EU=eu-central-1
AWS_S3_BUCKET_US=doctor8-files-us
AWS_S3_BUCKET_EU=doctor8-files-eu

# EMAIL — Resend
RESEND_API_KEY=re_...
# Resend webhook (Svix) — campaign delivery events (bounce, open, click)
# Dashboard: https://resend.com/webhooks → URL: https://app.doctor8.org/api/webhooks/resend
# RESEND_WEBHOOK_SECRET=whsec_...
# Use display name + verified domain (improves deliverability)
EMAIL_FROM=Doctor8 <noreply@doctor8.org>
# Reply-to for transactional mail (reduces spam score vs noreply-only)
EMAIL_REPLY_TO=support@doctor8.org
# SOS Venezuela — coordination inbox for triage/anamnesis alerts (comma-separated)
HUMANITARIAN_COORDINATION_EMAIL=coordenacion@acurabrasil.org
# Humanitarian patient signup — email verification is OFF by default (omit or leave unset).
# Set to 1 only if you need to re-enable verification for SOS / humanitarian flows.
# HUMANITARIAN_EMAIL_VERIFICATION_ENABLED=
# Humanitarian patient queue — phone verification gate is OFF by default.
# HUMANITARIAN_PHONE_GATE_ENABLED=
# ACURA Brasil / SOS Venezuela — server-to-server (Bearer token):
#   POST/GET /api/integrations/check-email
#   POST /api/integrations/acura/intakes
#   PATCH /api/integrations/acura/intakes/:protocolo
#   GET  /api/integrations/acura/volunteers  (diretório ACURABRASIL — perfil público + selo)
# Generate with: openssl rand -base64 32
# ACURA_PARTNER_API_KEY=
# Admin inbox when a provider uploads CRM/CRP documents (comma-separated; falls back to HUMANITARIAN_COORDINATION_EMAIL)
PROVIDER_VERIFICATION_NOTIFY_EMAIL=controladoria@doctor8.com.br

# ENCRYPTION — for PHI fields at rest (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your-32-byte-hex-key-here
# After deploy / migration: encrypt legacy org PHI (TissGuide, OrganizationEmployee)
# npm run backfill:org-phi:dry && npm run backfill:org-phi

# LACUNA REST PKI CORE — digital signature with cloud certificates (BirdID/VIDaaS)
# Request access at https://core.pki.rest (SaaS) and create an Application (role
# "Operador"/Worker), then a Key. The full key value (incl. the "app|" prefix) is
# what goes in LACUNA_API_KEY.
LACUNA_ENDPOINT=https://core.pki.rest
LACUNA_API_KEY=
# Free ITI test security context for development (sign without a real certificate).
# For production with real Vidaas/BirdID certificates, leave empty or use Lacuna's ICP-Brasil context.
# Using the test GUID below with real Vidaas certs can cause OAuth errors on certificado.vidaas.com.br.
LACUNA_SECURITY_CONTEXT=803517ad-3bbc-4169-b085-60053a8f6dbf

# SESSION
# HIPAA: sliding inactivity timeout — session expires after 15 min without user activity
SESSION_MAX_AGE_SECONDS=900
# Mirror for client inactivity warning (must match SESSION_MAX_AGE_SECONDS)
NEXT_PUBLIC_SESSION_MAX_AGE_SECONDS=900
# Throttle for extending session while active (default 60s)
# SESSION_UPDATE_AGE_SECONDS=60
# JIT plantão heartbeat timeout (defaults to SESSION_MAX_AGE_SECONDS)
# JIT_HEARTBEAT_TIMEOUT_SECONDS=900
# Extended session during active teleconsult (video room keepalive); default 2h
# SESSION_CONSULT_MAX_AGE_SECONDS=7200

# QSTASH — scheduled reminders (email, WhatsApp, review requests) + email campaign batches
# QSTASH_TOKEN=
# QSTASH_CURRENT_SIGNING_KEY=
# QSTASH_NEXT_SIGNING_KEY=

# WHATSAPP — Meta Cloud API (Doctor8 production — app 1647875149621067)
#
# WABA: Doctor8 (28086919737599570) · número +49 174 9803699 (Alemanha)
# Business ID: 1447894583459922
# Webhook: https://app.doctor8.org/api/webhooks/whatsapp
#
# Until Meta approves your utility templates, the app keeps working with wa.me
# link fallbacks (humanitarian handoff, manual share buttons, email links).
#
# Submit templates in Meta Business Manager (utility category):
#   - doctor8_appointment_reminder  (body: name, doctor, date/time)
#   - doctor8_clinical_document     (body: name, doctor, doc type, link)
# Approve each language you need: pt_BR, en_US, es
#
# Permanent token: Meta Business > System users (whatsapp_business_messaging +
# whatsapp_business_management). Do NOT use the 24h temporary token from API Setup.
WHATSAPP_ACCESS_TOKEN=
# Phone number ID (not the phone itself) — production: 1160816890453235
WHATSAPP_PHONE_NUMBER_ID=1160816890453235
# Optional — for admin dashboards and Meta console cross-reference
WHATSAPP_WABA_ID=28086919737599570
WHATSAPP_APP_ID=1647875149621067
# Utility template name approved in Meta Business Manager (default below)
WHATSAPP_REMINDER_TEMPLATE=doctor8_appointment_reminder
# Template for clinical document / prescription delivery (approve in Meta Business Manager)
# WHATSAPP_DOCUMENT_TEMPLATE=doctor8_clinical_document
# WHATSAPP_HUMANITARIAN_TURN_TEMPLATE=doctor8_humanitarian_your_turn
# WHATSAPP_PHARMACY_ORDER_TEMPLATE=pharmacy_order_paid_store_v1
WHATSAPP_TEMPLATE_LANG=pt_BR
# Default country code for recipient normalization (55 BR, 58 VE) — sender is +49
WHATSAPP_DEFAULT_COUNTRY_CODE=55
# Public wa.me target for Doctor8 support / partner contact (E.164 digits, no +)
NEXT_PUBLIC_DOCTOR8_WHATSAPP_PHONE=491749803699
WHATSAPP_GRAPH_API_VERSION=v25.0
# Set to 1 only if your template has a dynamic URL button (index 0)
# WHATSAPP_REMINDER_URL_BUTTON=0
# Webhook URL: https://app.doctor8.org/api/webhooks/whatsapp
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-random-verify-string
# App secret from Meta Developer Console (Settings > Basic) — validates POST webhook signatures
# WHATSAPP_APP_SECRET=
# Subscribe webhook fields: messages, message_template_status_update (and statuses for delivery logs)
#
# CHATWOOT — multi-agent inbox (Meta webhook stays on Doctor8; inbound POSTs are relayed)
# 1. Create WhatsApp Cloud API inbox at https://app.chatwoot.com (manual flow)
# 2. Use same Phone Number ID, WABA ID, and permanent access token as above
# 3. In Chatwoot inbox settings, copy the Webhook URL (format below) — do NOT change Meta callback URL
# 4. Add App Secret in Chatwoot inbox (same WHATSAPP_APP_SECRET) so signature verification works
# CHATWOOT_WHATSAPP_FORWARD_ENABLED=1
# CHATWOOT_WHATSAPP_FORWARD_URL=https://app.chatwoot.com/webhooks/whatsapp/+491749803699

# SMART on FHIR — third-party patient apps (public client + PKCE)
# SMART_OAUTH_CLIENT_ID=doctor8-public
# SMART_OAUTH_REDIRECT_URIS=http://localhost:3001/callback,https://your-app.example/callback
# Without SMART_OAUTH_REDIRECT_URIS, localhost callbacks are allowed in development.

# SSO OIDC — eight (rede social) login via Doctor8
# Generate secret: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# O MESMO secret vai em AUTH_DOCTOR8_SECRET no projeto eight (Railway).
SSO_EIGHT_CLIENT_ID=eight
SSO_EIGHT_CLIENT_SECRET=
SSO_EIGHT_REDIRECT_URIS=https://doctor8.com.br/api/auth/callback/doctor8

# SSO OIDC — vital8 (gestão clínica) login via Doctor8
# O MESMO secret vai em AUTH_DOCTOR8_SECRET no projeto vital8 (Railway).
SSO_VITAL8_CLIENT_ID=vital8
SSO_VITAL8_CLIENT_SECRET=
# Ex.: http://localhost:3001/api/auth/callback/doctor8 — vazio permite só localhost/127.0.0.1 em dev
SSO_VITAL8_REDIRECT_URIS=
# Obrigatório em produção (Railway multi-instância). Gerar: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048
# Cole o PEM inteiro em uma linha com \n escapado, ou use multiline no painel Railway.
# SSO_OAUTH_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----"

# SMS — AWS SNS (uses AWS credentials above)
# Keep disabled until AWS approves SMS production access (sandbox only sends to verified numbers).
# AWS_SNS_SMS_ENABLED=1
# Set after AWS Service Quotas approves TextMessageMonthlySpend (ticket in us-east-1):
# AWS_SNS_SMS_PRODUCTION=1
# Region for SMS — us-east-1 recommended for international SMS
AWS_SNS_REGION=us-east-1
# Optional sender ID (not supported in all countries, e.g. US/CA block custom sender IDs)
# AWS_SNS_SENDER_ID=Doctor8
SMS_DEFAULT_COUNTRY_CODE=55

# SMS — Twilio (optional fallback if AWS SNS not configured)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=
# TWILIO_SMS_FROM=

# PHARMACY — CMED reference prices (Medicamentos API.br / ANVISA) only
# Reference pricing is on by default; set false to hide the price lookup panel.
# Doctor8 does NOT sell medications — UI has no purchase/checkout (save-to-list is for personal records only).
PHARMACY_REFERENCE_ENABLED=true
MEDICAMENTOS_API_BR_BASE_URL=https://medicamentos.api.br
# Partner deeplink (Consulta Remédios) — opens partner search via /api/patient/pharmacy/out
# PHARMACY_MARKETPLACE_ENABLED=true
PHARMACY_MARKETPLACE_ENABLED=false
PHARMACY_PROVIDER=consulta-remedios
PHARMACY_PARTNER_BASE_URL=https://consultaremedios.com.br
# UTM tracking — keep false until Consulta Remédios whitelists Doctor8 (utm can trigger Cloudflare block)
PHARMACY_UTM_ENABLED=false
# Affiliate / tracking (also enables UTM when PHARMACY_AFFILIATE_ID is set)
PHARMACY_AFFILIATE_ID=
PHARMACY_UTM_SOURCE=doctor8
PHARMACY_UTM_MEDIUM=referral
PHARMACY_UTM_CAMPAIGN=medications
# Full API integration (optional — enables in-app price offers when both are set)
PHARMACY_API_BASE_URL=
PHARMACY_API_KEY=

# ANTHROPIC — clinical AI summaries (document analysis, consult notes)
ANTHROPIC_API_KEY=

# PSYCHOLOGY — feature flags (default ON when unset)
# PSYCHOLOGY_ANAMNESIS_ENABLED=true
# PSYCHOLOGY_AI_NOTES_ENABLED=true
# PSYCHOLOGY_RECEITA_SAUDE_ENABLED=true
# PSYCHOLOGY_24H_WHATSAPP_ENABLED=true
# PSYCHOLOGY_RISK_ALERTS_ENABLED=true
# PSYCHOLOGY_GOOGLE_CALENDAR_ENABLED=true
# PSYCHOLOGY_CHART_CHAT_ENABLED=true

# OPENAI — optional, for consult audio transcription (Whisper)
OPENAI_API_KEY=

# COMPLIANCE
HIPAA_MODE=true      # Enables extra HIPAA controls for US users
GDPR_MODE=true       # Enables GDPR controls for EU users
DPO_EMAIL=dpo@doctor8.org   # Data Protection Officer email (GDPR)

# CRON JOBS (Railway scheduled HTTP — header x-cron-secret: $CRON_SECRET)
# CRON_SECRET=generate-with-openssl-rand-hex-32
# POST /api/cron/reminders              — daily (re-schedule appointment reminders)
# POST /api/cron/post-consult-notes     — every 2–4h (fallback for QStash post-consult notes)
# POST /api/cron/consultation-payouts   — hourly (Stripe Connect transfers after cancel/refund window)
# POST /api/cron/humanitarian           — as needed
# POST /api/cron/smart-cleanup          — weekly

# QSTASH (Upstash — delayed reminders + post-consult notes)
# QSTASH_TOKEN=
# QSTASH_CURRENT_SIGNING_KEY=
# QSTASH_NEXT_SIGNING_KEY=

# MONITORING (optional — errors only; disabled when unset)
# 1. Create project at sentry.io → Settings → Client Keys (DSN)
# 2. Railway production: set SENTRY_DSN=https://...@....ingest.sentry.io/...
# 3. Verify after deploy: Admin → Integrations shows "Sentry active"
# 4. Optional client fallback (only if browser errors don't appear server-side): NEXT_PUBLIC_SENTRY_DSN=same value
# 5. Redeploy after setting — DSN is read at build/runtime on the server
SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# WEB PUSH (optional — browser notifications alongside in-app bell)
# Generate: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=   # same value as VAPID_PUBLIC_KEY for the client
# VAPID_SUBJECT=mailto:support@doctor8.org

# E2E / Playwright (local or CI — optional; auth tests skip when unset locally)
# PLAYWRIGHT_BASE_URL=http://localhost:3000
# Run: npm run seed:e2e && npm run test:e2e
# Defaults for CI (also used when E2E_* unset in CI):
# E2E_PATIENT_EMAIL=e2e-patient@doctor8.test
# E2E_PATIENT_PASSWORD=TestPassword1!
# E2E_PROFESSIONAL_EMAIL=e2e-volunteer@doctor8.test
# E2E_PROFESSIONAL_PASSWORD=TestPassword1!
# E2E_PSYCHOLOGIST_EMAIL=e2e-psychologist@doctor8.test
# E2E_PSYCHOLOGIST_PASSWORD=TestPassword1!
# E2E_ADMIN_EMAIL=e2e-admin@doctor8.test
# E2E_ADMIN_PASSWORD=TestPassword1!
