}

model IntegrativeTherapistAvailabilitySlot {
  id                    String                      @id @default(cuid())
  integrativeTherapistId String
  integrativeTherapist  IntegrativeTherapistProfile @relation(fields: [integrativeTherapistId], references: [id], onDelete: Cascade)

  dayOfWeek        Int
  startTime        String
  endTime          String
  slotDurationMins Int    @default(50)
  slotGapMins      Int    @default(0)
  isActive         Boolean @default(true)

  @@index([integrativeTherapistId])
}

// ─────────────────────────────────────────
// MEDICATIONS (FIX: two separate flows)
// ─────────────────────────────────────────

model Medication {
  id              String         @id @default(cuid())
  patientId       String
  patient         PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  name            String         // @encrypted — PHI
  dosage          String?        // @encrypted — PHI
  frequency       String?        // @encrypted — PHI
  startDate       DateTime?
  endDate         DateTime?
  prescribedBy    String?
  notes           String?        // @encrypted

  // THE FIX: separates clinical from purchase
  flow            MedicationFlow @default(CLINICAL)

  // PURCHASE flow: linked to DrugCatalog + CMED reference at save time
  drugCatalogId       String?
  referencePriceCents Int?

  active          Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([patientId])
  @@index([flow])  // allows querying clinical vs purchase separately
}

// ─────────────────────────────────────────
// APPOINTMENTS + SCHEDULING
// ─────────────────────────────────────────

model AvailabilitySlot {
  id               String              @id @default(cuid())
  professionalId   String
  professional     ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  dayOfWeek        Int    // 0=Sunday, 6=Saturday
  startTime        String // "09:00"
  endTime          String // "17:00"
  slotDurationMins Int    @default(30)
  slotGapMins      Int    @default(0)
  volunteerOnly    Boolean @default(false)
  isActive         Boolean @default(true)

  @@index([professionalId])
}

model Appointment {
  id               String              @id @default(cuid())
  patientId        String
  patient          PatientProfile      @relation(fields: [patientId], references: [id])
  providerType     ProviderType        @default(HEALTH)
  professionalId   String?
  professional     ProfessionalProfile? @relation(fields: [professionalId], references: [id])
  psychoanalystId  String?
  psychoanalyst    PsychoanalystProfile? @relation(fields: [psychoanalystId], references: [id])
  integrativeTherapistId String?
  integrativeTherapist   IntegrativeTherapistProfile? @relation(fields: [integrativeTherapistId], references: [id])

  scheduledAt      DateTime
  durationMins     Int                 @default(30)
  type             AppointmentType     @default(TELECONSULT)
  status           AppointmentStatus   @default(PENDING)

  // Teleconsult
  videoChannel     AppointmentVideoChannel @default(DAILY)
  meetingUrl       String?
  meetingRoomId    String?

  // Payment
  priceAmount      Int     // in cents
  currency         String  @default("USD")
  stripePaymentId  String?  @unique
  paidAt           DateTime?

  // Clinical
  chiefComplaint   String? // @encrypted — PHI
  notes            String? // @encrypted — PHI

  // Reminders sent
  reminder24hSent  Boolean @default(false)
  reminder1hSent   Boolean @default(false)
  reviewRequestSent Boolean @default(false)
  remindersEpoch   Int     @default(0)

  bookingSource    String?  // patient_panel | public_profile | public_search

  // Dental clinic — optional chair assignment
  dentalChairId    String?
  dentalChair      DentalChair? @relation(fields: [dentalChairId], references: [id], onDelete: SetNull)

  cancelledAt      DateTime?
  cancelledBy      String?
  cancelReason     String?

  patientConfirmedAt DateTime?
  patientJoinedAt    DateTime?
  professionalJoinedAt DateTime?

  adminProblemAt   DateTime?
  adminProblemNote String?
  adminProblemById String?

  googleCalendarEventId String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  documents        MedicalDocument[]

  @@index([patientId])
  @@index([professionalId])
  @@index([psychoanalystId])
  @@index([integrativeTherapistId])
  @@index([providerType])
  @@index([scheduledAt])
  @@index([status])
}

// Stripe webhook idempotency — one row per event.id after side effects complete.
model ProcessedStripeEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique
  type        String
  status      String   // PROCESSED | FAILED
  error       String?
  processedAt DateTime @default(now())
}

model PaymentRefund {
  id              String   @id @default(cuid())
  paymentIntentId String
  stripeRefundId  String?  @unique
  reason          String
  amountCents     Int?
  currency        String?
  status          String   // SUCCEEDED | ALREADY_REFUNDED | FAILED
  triggeredBy     String   // AUTO_SLOT_TAKEN | AUTO_WEBHOOK_FAIL | PATIENT_CANCEL | JIT_ORPHAN | JIT_QUEUE | OTHER
  appointmentId   String?
  userId          String?
  createdAt       DateTime @default(now())

  @@index([paymentIntentId])
  @@index([createdAt])
}

// ─────────────────────────────────────────
// MEDICAL DOCUMENTS + CARDS
// ─────────────────────────────────────────

model MedicalDocument {
  id               String              @id @default(cuid())
  patientId        String?
  patient          PatientProfile?     @relation(fields: [patientId], references: [id])
  patientRecordId  String?
  patientRecord    PatientRecord?      @relation(fields: [patientRecordId], references: [id])
  professionalId   String?
  professional     ProfessionalProfile? @relation(fields: [professionalId], references: [id])
  psychoanalystId  String?
  psychoanalyst    PsychoanalystProfile? @relation(fields: [psychoanalystId], references: [id])
  analysandRecordId String?
  analysandRecord  AnalysandRecord?    @relation(fields: [analysandRecordId], references: [id])
  integrativeTherapistId String?
  integrativeTherapist   IntegrativeTherapistProfile? @relation(fields: [integrativeTherapistId], references: [id])
  integrativeClientRecordId String?
  integrativeClientRecord   IntegrativeClientRecord? @relation(fields: [integrativeClientRecordId], references: [id])
  appointmentId    String?
  appointment      Appointment?        @relation(fields: [appointmentId], references: [id])

  type             DocumentType
  recordKind       ClinicalRecordKind @default(OTHER)
  categoryId       String?
  category         Category?    @relation(fields: [categoryId], references: [id])
  title            String       // @encrypted
  content          String?      @db.Text  // @encrypted — PHI
  fileUrl          String?      // S3 URL — @encrypted

  // When this record is a COPY of a document shared by a patient (4D/3D-2),
  // this points to the original shared document (to prevent duplicates).
  sourceDocumentId String?

  // Sharing
  sharedRecords    SharedRecord[]

  // Digital signature via Lacuna (same flow as Prescription)
  signatureSessionId String?
  signatureStatus    String?   // PENDING | SIGNED | CANCELLED | ERROR
  signedFileUrl      String?   // S3 key of signed PDF
  signedAt           DateTime?
  digitalSignature   String?
  patientNotifiedAt  DateTime?
  whatsappNotifiedAt DateTime?
  whatsappNotifyStatus String? // SENT | FAILED | NO_PHONE | SKIPPED

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  prescriptions    Prescription[]

  @@index([patientId])
  @@index([patientRecordId])
  @@index([analysandRecordId])
  @@index([integrativeClientRecordId])
  @@index([psychoanalystId])
  @@index([integrativeTherapistId])
  @@index([type])
  @@index([categoryId])
  @@index([recordKind])
}

model SharedRecord {
  id               String           @id @default(cuid())
  documentId       String
  document         MedicalDocument  @relation(fields: [documentId], references: [id])
  patientId        String
  patient          PatientProfile   @relation(fields: [patientId], references: [id])

  // Who can access
  sharedWithEmail  String?   // external share
  sharedWithUserId String?   // internal share

  // Direction of the share (Phase 4D)
  sharedByUserId            String?              // NEW — who shared it (patient, when patient->doctor)
  sharedWithProfessionalId  String?              // NEW — recipient professional (patient->doctor)
  sharedWithProfessional    ProfessionalProfile? @relation("DocsSharedWithProfessional", fields: [sharedWithProfessionalId], references: [id]) // NEW

  accessToken      String    @unique @default(cuid()) // for link sharing
  expiresAt        DateTime? // null = never expires
  viewedAt         DateTime?

  createdAt        DateTime  @default(now())

  @@index([patientId])
  @@index([accessToken])
  @@index([sharedWithProfessionalId])
}

// Consent-based patient ↔ medical professional link (prescribe/search without full chart read).
model PatientProfessionalLink {
  id                 String                        @id @default(cuid())
  patientUserId      String
  professionalUserId String
  status             PatientProfessionalLinkStatus @default(PENDING)
  requestedBy        String                        // "PROFESSIONAL" | "PATIENT"
  createdAt          DateTime                      @default(now())
  respondedAt        DateTime?

  patient      User @relation("PatientProfessionalLinkPatient", fields: [patientUserId], references: [id], onDelete: Cascade)
  professional User @relation("PatientProfessionalLinkProfessional", fields: [professionalUserId], references: [id], onDelete: Cascade)

  @@unique([patientUserId, professionalUserId])
  @@index([professionalUserId, status])
  @@index([patientUserId, status])
}

// Patient report: "I don't know this professional" after unsolicited emission.
model ProfessionalEmissionReport {
  id                 String   @id @default(cuid())
  patientUserId      String
  professionalUserId String
  resourceType       String   // PRESCRIPTION | EXAM_REQUEST | ...
  resourceId         String
  createdAt          DateTime @default(now())

  patient      User @relation("EmissionReportPatient", fields: [patientUserId], references: [id], onDelete: Cascade)
  professional User @relation("EmissionReportProfessional", fields: [professionalUserId], references: [id], onDelete: Cascade)

  @@index([professionalUserId])
  @@index([patientUserId])
}

model Prescription {
  id               String              @id @default(cuid())
  documentId       String?
  document         MedicalDocument?    @relation(fields: [documentId], references: [id])
  professionalId   String?
  professional     ProfessionalProfile? @relation(fields: [professionalId], references: [id])
  integrativeTherapistId String?
  integrativeTherapist   IntegrativeTherapistProfile? @relation(fields: [integrativeTherapistId], references: [id])

  // @encrypted — all PHI
  medications      Json    // [{name, dosage, frequency, duration, instructions}]
  instructions     String? // @encrypted
  validUntil       DateTime?
  digitalSignature String? // professional's signature reference (e.g. Lacuna session id)

  // Digital signature via Lacuna Rest PKI Core (cloud certificate / PAdES)
  signatureSessionId String?   // Rest PKI Core signature session id
  signatureStatus    String?   // PENDING | SIGNED | CANCELLED | ERROR
  signedFileUrl      String?   // S3 key of the signed PDF
  signedAt           DateTime?
  patientNotifiedAt  DateTime?
  whatsappNotifiedAt DateTime?
  whatsappNotifyStatus String? // SENT | FAILED | NO_PHONE | SKIPPED

  createdAt        DateTime @default(now())

  @@index([professionalId])
  @@index([integrativeTherapistId])
}

// ─────────────────────────────────────────
// MESSAGING
// ─────────────────────────────────────────

model Message {
  id          String   @id @default(cuid())
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId  String
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id])

  content     String   @db.Text  // @encrypted — may contain PHI
  readAt      DateTime?
  deletedAt   DateTime?

  createdAt   DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
}

// ─────────────────────────────────────────
// PAYMENTS + SUBSCRIPTIONS
// ─────────────────────────────────────────

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id])

  stripeCustomerId     String   @unique
  stripeSubscriptionId String?  @unique
  stripePriceId        String?

  status               String   // active, cancelled, past_due, trialing
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean  @default(false)

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ─────────────────────────────────────────
// PROFESSIONAL VIRTUAL CARD
// ─────────────────────────────────────────

model VirtualCard {
  id              String                @id @default(cuid())
  professionalId  String?               @unique
  professional    ProfessionalProfile?  @relation("ProfessionalVirtualCard", fields: [professionalId], references: [id])
  psychoanalystId String?               @unique
  psychoanalyst   PsychoanalystProfile? @relation("PsychoanalystVirtualCard", fields: [psychoanalystId], references: [id])
  integrativeTherapistId String?               @unique
  integrativeTherapist   IntegrativeTherapistProfile? @relation("IntegrativeTherapistVirtualCard", fields: [integrativeTherapistId], references: [id])

  slug            String                @unique
  specialtySlug   String                @default("")
  citySlug        String                @default("")
  headline        String?
  website         String?
  googleBusinessUrl String?
  socialLinks     Json?
  isPublic        Boolean               @default(false)

  profileEvents   PublicProfileEvent[]

  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([specialtySlug, citySlug])
}

enum PublicProfileEventType {
  VIEW
  BOOK_CLICK
}

model PublicProfileEvent {
  id            String                 @id @default(cuid())
  virtualCardId String
  virtualCard   VirtualCard            @relation(fields: [virtualCardId], references: [id], onDelete: Cascade)
  type          PublicProfileEventType
  source        String?
  createdAt     DateTime               @default(now())

  @@index([virtualCardId, createdAt])
  @@index([virtualCardId, type, createdAt])
}

// ─────────────────────────────────────────
// HEALTH PLANS (convênios) — public search filter
// ─────────────────────────────────────────

model HealthPlan {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  sortOrder Int      @default(0)

  professionals  ProfessionalHealthPlan[]
  psychoanalysts PsychoanalystHealthPlan[]
  integrativeTherapists IntegrativeTherapistHealthPlan[]
  organizations  OrganizationHealthPlan[]

  @@index([sortOrder])
}

model ProfessionalHealthPlan {
  professionalId String
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  healthPlanId   String
  healthPlan     HealthPlan          @relation(fields: [healthPlanId], references: [id], onDelete: Cascade)

  allowedWeekdays Int[] @default([]) // empty = all days the provider is open
  minLeadDays     Int   @default(0)  // minimum booking advance (days)

  @@id([professionalId, healthPlanId])
  @@index([healthPlanId])
}

model PsychoanalystHealthPlan {
  psychoanalystId String
  psychoanalyst   PsychoanalystProfile @relation(fields: [psychoanalystId], references: [id], onDelete: Cascade)
  healthPlanId    String
  healthPlan      HealthPlan           @relation(fields: [healthPlanId], references: [id], onDelete: Cascade)

  allowedWeekdays Int[] @default([])
  minLeadDays     Int   @default(0)

  @@id([psychoanalystId, healthPlanId])
  @@index([healthPlanId])
}

model IntegrativeTherapistHealthPlan {
  integrativeTherapistId String
  integrativeTherapist   IntegrativeTherapistProfile @relation(fields: [integrativeTherapistId], references: [id], onDelete: Cascade)
  healthPlanId           String
  healthPlan             HealthPlan                  @relation(fields: [healthPlanId], references: [id], onDelete: Cascade)

  allowedWeekdays Int[] @default([])
  minLeadDays     Int   @default(0)

  @@id([integrativeTherapistId, healthPlanId])
  @@index([healthPlanId])
}

// ─────────────────────────────────────────
// PRACTICE LOCATIONS + SERVICES (public profile)
// ─────────────────────────────────────────

model PracticeLocation {
  id              String                @id @default(cuid())
  professionalId  String?
  professional    ProfessionalProfile?  @relation("ProfessionalLocations", fields: [professionalId], references: [id], onDelete: Cascade)
  psychoanalystId String?
  psychoanalyst   PsychoanalystProfile? @relation("PsychoanalystLocations", fields: [psychoanalystId], references: [id], onDelete: Cascade)
  integrativeTherapistId String?
  integrativeTherapist   IntegrativeTherapistProfile? @relation("IntegrativeTherapistLocations", fields: [integrativeTherapistId], references: [id], onDelete: Cascade)

  name            String
  address         String
  city            String
  state           String?
  country         String?
  zip             String?
  latitude        Float?
  longitude       Float?
  isPrimary       Boolean  @default(false)
  sortOrder       Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([professionalId])
  @@index([psychoanalystId])
  @@index([integrativeTherapistId])
}

model ProviderService {
  id              String                @id @default(cuid())
  professionalId  String?
  professional    ProfessionalProfile?  @relation("ProfessionalServices", fields: [professionalId], references: [id], onDelete: Cascade)
  psychoanalystId String?
  psychoanalyst   PsychoanalystProfile? @relation("PsychoanalystServices", fields: [psychoanalystId], references: [id], onDelete: Cascade)
  integrativeTherapistId String?
  integrativeTherapist   IntegrativeTherapistProfile? @relation("IntegrativeTherapistServices", fields: [integrativeTherapistId], references: [id], onDelete: Cascade)

  name            String
  description     String?
  priceCents      Int?
  currency        String   @default("BRL")
  isReturnService Boolean  @default(false)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([professionalId])
  @@index([psychoanalystId])
  @@index([integrativeTherapistId])
}

model SlotAvailabilityAlert {
  id              String                @id @default(cuid())
  professionalId  String?
  professional    ProfessionalProfile?  @relation("ProfessionalSlotAlerts", fields: [professionalId], references: [id], onDelete: Cascade)
  psychoanalystId String?
  psychoanalyst   PsychoanalystProfile? @relation("PsychoanalystSlotAlerts", fields: [psychoanalystId], references: [id], onDelete: Cascade)

  email           String
  slug            String
  active          Boolean  @default(true)
  notifiedAt      DateTime?

  createdAt       DateTime @default(now())

  @@unique([email, professionalId])
  @@unique([email, psychoanalystId])
  @@index([slug])
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String
  body      String
  type      String   // appointment_reminder, message, payment, system
  data      Json?
  readAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([readAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Patient favorites (map) + optional online alert
model PatientFavorite {
  id             String              @id @default(cuid())
  patientUserId  String
  patientUser    User                @relation("PatientFavorites", fields: [patientUserId], references: [id], onDelete: Cascade)
  professionalId String
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  notifyOnline   Boolean             @default(true)
  createdAt      DateTime            @default(now())

  @@unique([patientUserId, professionalId])
  @@index([professionalId])
}

model PsychoanalystFavorite {
  id              String              @id @default(cuid())
  patientUserId   String
  psychoanalystId String
  psychoanalyst   PsychoanalystProfile  @relation(fields: [psychoanalystId], references: [id], onDelete: Cascade)
  notifyOnline    Boolean             @default(true)
  createdAt       DateTime            @default(now())

  @@unique([patientUserId, psychoanalystId])
  @@index([psychoanalystId])
}

// Patient reviews of professionals (1 per patient per professional)
model ProfessionalReview {
  id             String              @id @default(cuid())
  patientUserId  String
  patientUser    User                @relation("PatientReviews", fields: [patientUserId], references: [id], onDelete: Cascade)
  professionalId String
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  rating         Int                 // 1–5
  comment        String?             @db.Text
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([patientUserId, professionalId])
  @@index([professionalId])
}

model PsychoanalystReview {
  id              String              @id @default(cuid())
  patientUserId   String
  psychoanalystId String
  psychoanalyst   PsychoanalystProfile @relation(fields: [psychoanalystId], references: [id], onDelete: Cascade)
  rating          Int
  comment         String?             @db.Text
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([patientUserId, psychoanalystId])
  @@index([psychoanalystId])
}

// ─────────────────────────────────────────
// COMPLIANCE — HIPAA + GDPR
// ─────────────────────────────────────────

// Every access to PHI must create an audit log — HIPAA requirement
model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  user        User?       @relation(fields: [userId], references: [id])

  action      AuditAction
  resource    String      // e.g. "PatientProfile", "MedicalDocument"
  resourceId  String?
  ipAddress   String?     // @encrypted
  userAgent   String?
  details     Json?       // additional context, never store PHI here

  createdAt   DateTime    @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// Explicit consent tracking — GDPR requirement
model Consent {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        ConsentType
  version     String      // "1.0", "1.1" etc — matches document version
  granted     Boolean
  grantedAt   DateTime    @default(now())
  revokedAt   DateTime?
  ipAddress   String?     // @encrypted
  userAgent   String?

  @@unique([userId, type, version])
  @@index([userId])
}

// GDPR right to data portability + right to erasure
model DataExportRequest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  type        String   // "export" or "deletion"
  status      String   @default("pending") // pending, processing, completed, failed
  fileUrl     String?  // S3 URL of export ZIP (for export requests)
  completedAt DateTime?
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// ────────────────────────────────────────────
// PATIENT RECORD (chart created by a professional)
// A patient "file" the doctor keeps. May or may not be linked
// to a real user account (linkedUserId). Nothing is shared with
// the patient until the doctor explicitly shares it.
// ────────────────────────────────────────────
model PatientRecord {
  id              String   @id @default(cuid())
  professionalId  String
  professional    ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  // Patient data filled by the professional — @encrypted in app layer (PHI)
  firstName       String   // @encrypted
  lastName        String   // @encrypted
  email           String?  // used to link/invite the patient
  phone           String?  // @encrypted
  dateOfBirth     String?   // @encrypted — ISO date string YYYY-MM-DD
  notes           String?  @db.Text // @encrypted — general chart notes
  cpf             String?  // @encrypted — opcional (paciente no exterior pode não ter)
  sex             String?  // opcional — "M", "F", "O" ou livre
  addressLine1    String?  // @encrypted — rua, número, complemento
  city            String?
  state           String?  // estado/província/região
  country         String?  @default("BR")
  zipCode         String?  // @encrypted — CEP / ZIP / código postal

  // Link to a real account, once the patient has one
  linkedUserId    String?
  // Normalized plaintext for search (first + last + email, accent-stripped)
  searchText      String?
  // Clinical records attached to this chart
  medicalDocuments MedicalDocument[]
  resourceShares   ResourceShare[]
  tags             PatientRecordTag[]
  diagnoses        PatientDiagnosis[]
  metricSnapshots  ClinicalMetricSnapshot[]
  vaccinations     PatientVaccination[]
  odontogram         PatientOdontogram?
  audiograms         PatientAudiogram[]
  colleagueShares  PatientRecordShare[]
  chartInvites     PatientChartInvite[]
  psychologyAnamnesisInvites PsychologyAnamnesisInvite[]
  nutritionAnthropometry NutritionAnthropometryEntry[]
  nutritionMealPlans     NutritionMealPlan[]
  nutritionIntakeForms   NutritionIntakeForm[]
  nutritionFoodAnamnesis NutritionFoodAnamnesis[]
  nutritionFoodDiary     NutritionFoodDiaryEntry[]
  nursingAssessments     NursingAssessment[]
  nursingCarePlans       NursingCarePlan[]
  nursingScaleEntries    NursingScaleEntry[]
  nursingIntakeForms     NursingIntakeForm[]
  nursingMonitoring      NursingMonitoringEntry[]
  nursingSbarReports     NursingSbarReport[]
  nursingMedChecks       NursingMedCheck[]
  nursingMedicationRx    NursingMedicationPrescription[]
  pharmacyIntakeForms    PharmacyIntakeForm[]
  pharmacyMedReviews     PharmacyMedReview[]
  pharmacyReconciliations PharmacyReconciliation[]
  pharmacyMonitoring     PharmacyMonitoringEntry[]
  pharmacyPrescriptions  PharmacyPrescription[]
  pharmacyEducationSessions PharmacyEducationSession[]
  pharmacyDispensingRecords PharmacyDispensingRecord[]
  pharmacyInteractionChecks PharmacyInteractionCheck[]
  dentalAnamnesis          DentalAnamnesis[]
  dentalTreatmentPlans     DentalTreatmentPlan[]
  dentalProstheticOrders   DentalProstheticOrder[]
  orthodonticRecords       OrthodonticRecord[]
  dentalClinicalPhotos     DentalClinicalPhoto[]
  periodontograms          PatientPeriodontogram[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([professionalId])
  @@index([email])
  @@index([linkedUserId])
  @@index([searchText])

}

model PatientChartInvite {
  id                   String                   @id @default(cuid())
  patientRecordId      String
  patientRecord        PatientRecord            @relation(fields: [patientRecordId], references: [id], onDelete: Cascade)
  sentByProfessionalId String
  sentBy               ProfessionalProfile      @relation(fields: [sentByProfessionalId], references: [id], onDelete: Cascade)
  email                String
  status               PatientChartInviteStatus @default(SENT)
  sentAt               DateTime                 @default(now())
  linkedAt             DateTime?

  @@index([patientRecordId])
  @@index([email])
  @@index([sentByProfessionalId])
}

model PsychologyAnamnesisInvite {
  id              String                    @id @default(cuid())
  token           String                    @unique @default(cuid())
  patientRecordId String
  patientRecord   PatientRecord             @relation(fields: [patientRecordId], references: [id], onDelete: Cascade)
  professionalId  String
  professional    ProfessionalProfile       @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  status          PsychologyAnamnesisStatus @default(PENDING)
  responses       String?                   @db.Text // @encrypted JSON
  expiresAt       DateTime
  completedAt     DateTime?
  createdAt       DateTime                  @default(now())

  @@index([token])
  @@index([patientRecordId])
  @@index([professionalId])
  @@index([status])
}

model ProfessionalGoogleCalendar {
  id               String              @id @default(cuid())
  professionalId   String              @unique
  professional     ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  refreshToken     String              // @encrypted
  accessToken      String?             // @encrypted
  tokenExpiresAt   DateTime?
