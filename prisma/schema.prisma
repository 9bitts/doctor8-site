// ─────────────────────────────────────────
// JUST-IN-TIME — Plantão Online
// ─────────────────────────────────────────

model JitSession {
  id              String              @id @default(cuid())
  professionalId  String
  professional    ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  mode            JitMode             @default(QUEUE)
  status          JitSessionStatus    @default(OFFLINE)
  specialty       String              // e.g. "Medicina Geral", "Psicologia"

  // Pricing — 0 = gratuito
  priceAmount     Int                 @default(0)  // in cents
  currency        String              @default("BRL")
  isFree          Boolean             @default(true)

  // Queue settings
  maxQueueSize            Int         @default(50)
  estimatedMinutesPerPatient Int      @default(20)
  noShowTimeoutSeconds    Int         @default(120) // 2 minutes

  // Event link (optional — for emergency events like RS floods)
  jitEventId      String?
  jitEvent        JitEvent?           @relation(fields: [jitEventId], references: [id])

  queue           JitQueue[]

  lastHeartbeatAt DateTime?           // updated while professional is active on plantão

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([professionalId])
  @@index([status])
  @@index([specialty])
  @@index([lastHeartbeatAt])
}

model JitQueue {
  id              String          @id @default(cuid())
  sessionId       String
  session         JitSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Patient — must have account (login required)
  patientUserId   String
  patientUser     User            @relation("JitQueuePatient", fields: [patientUserId], references: [id])

  status          JitQueueStatus  @default(WAITING)
  position        Int             // position in queue (recalculated on each change)
  specialty       String          // what the patient needs

  // Timestamps
  enteredAt       DateTime        @default(now())
  calledAt        DateTime?       // when professional clicked "call next"
  expiresAt       DateTime?       // calledAt + noShowTimeoutSeconds
  startedAt       DateTime?       // when patient clicked "enter"
  endedAt         DateTime?       // when session ended

  // Video room
  meetingUrl      String?         // Daily.co room URL
  meetingRoomId   String?

  // Payment
  paymentId       String?         @unique
  payment         JitPayment?     @relation(fields: [paymentId], references: [id])

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([sessionId])
  @@index([patientUserId])
  @@index([status])
}

model JitPayment {
  id                String    @id @default(cuid())
  amount            Int       // in cents
  currency          String    @default("BRL")
  stripePaymentId   String?   @unique
  paidAt            DateTime?
  status            String    @default("pending") // pending | paid | refunded | failed

  queueEntry        JitQueue?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model JitEvent {
  id          String    @id @default(cuid())
  name        String    // e.g. "Ação RS — Enchentes 2024"
  description String?
  startAt     DateTime
  endAt       DateTime?

  // Force all sessions in this event to be free
  forceFree   Boolean   @default(true)

  // Which specialties are part of this event
  specialties String[]  @default([])

  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  sessions    JitSession[]
}

// ─────────────────────────────────────────
// HUMANITARIAN CARE — pooled queues (e.g. Venezuela earthquake relief)
// Patients join a specialty pool; dispatcher assigns next free volunteer.
// ─────────────────────────────────────────

model HumanitarianCampaign {
  id                       String    @id @default(cuid())
  slug                     String    @unique
  name                     String
  description              String?
  region                   String?   @db.VarChar(2)
  active                   Boolean   @default(true)
  startAt                  DateTime  @default(now())
  endAt                    DateTime?

  noShowTimeoutSeconds     Int       @default(180)
  estimatedMinutesPerPatient Int     @default(15)

  pools                    HumanitarianPool[]
  volunteers               HumanitarianVolunteer[]
  angels                   HumanitarianAngel[]
  entries                  HumanitarianQueueEntry[]
  intakes                  HumanitarianIntake[]
  angelFollowUps           HumanitarianAngelFollowUp[]
  angelAssignments         HumanitarianAngelAssignment[]

  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([active])
  @@index([slug])
}

model HumanitarianIntake {
  id                  String                   @id @default(cuid())
  campaignId          String
  campaign            HumanitarianCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  patientUserId       String
  patientUser         User                     @relation("HumanitarianIntakePatient", fields: [patientUserId], references: [id], onDelete: Cascade)

  triageData          Json?
  triageCompletedAt   DateTime?
  computedPriority    HumanitarianPriority?
  triageFlags         String[]                 @default([])
  forceMedicalPool    Boolean                  @default(false)

  identificationData  Json?
  serviceTypes        String[]                 @default([])
  specialtyData       Json?
  basicNeedsData      Json?
  consentAt           DateTime?
  telemedicineTcleAt  DateTime?
  telemedicineTcleVersion String?
  angelContactConsentAt DateTime?
  angelContactConsentVersion String?
  additionalNotes     String?

  status              HumanitarianIntakeStatus @default(TRIAGE_ONLY)

  entries             HumanitarianQueueEntry[]

  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@unique([campaignId, patientUserId])
  @@index([campaignId, status])
  @@index([campaignId, computedPriority])
  @@index([patientUserId])
}

model HumanitarianPool {
  id           String               @id @default(cuid())
  campaignId   String
  campaign     HumanitarianCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  slug         String               // medico | psicologo | psicanalista | terapeuta_integrativo | fisioterapeuta | nutricionista | cuidados_paliativos
  labelEs      String
  labelPt      String
  labelEn      String
  maxWaiting   Int                  @default(500)
  sortOrder    Int                  @default(0)

  entries      HumanitarianQueueEntry[]
  volunteers   HumanitarianVolunteer[]

  @@unique([campaignId, slug])
  @@index([campaignId])
