// ────────────────────────────────────────────
// ORGANIZATION — CNPJ clinic / consultório management (Phase 1)
// ────────────────────────────────────────────

model Organization {
  id                   String   @id @default(cuid())
  cnpj                 String   @unique
  razaoSocial          String
  nomeFantasia         String
  inscricaoMunicipal   String?
  contactEmail         String?
  contactPhone         String?
  logoUrl              String?
  slug                 String   @unique
  inviteCode           String   @unique @default(cuid())

  responsibleFirstName String
  responsibleLastName  String

  addressStreet        String?
  addressNumber        String?
  addressComplement    String?
  addressNeighborhood  String?
  addressCity          String?
  addressState         String?
  addressZip           String?
  addressCountry       String   @default("BR")

  timezone             String   @default("America/Sao_Paulo")
  currency             String   @default("BRL")
  whatsappRemindersEnabled Boolean @default(true)

  members              OrganizationMember[]
  professionals        OrganizationProfessional[]
  linkedProviders      OrganizationLinkedProvider[]
  repasseRules         OrganizationRepasseRule[]
  invites              OrganizationInvite[]
  ledgerEntries        OrganizationLedgerEntry[]
  healthPlans          OrganizationHealthPlan[]
