  batchNumber     String
  periodStart     DateTime
  periodEnd       DateTime
  status          TissBatchStatus @default(OPEN)
  totalGuides     Int             @default(0)
  totalAmountCents Int            @default(0)

  guides          TissGuide[]
  sentAt          DateTime?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([organizationId])
  @@index([orgHealthPlanId])
}

model OrganizationEmployee {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  professionalId String?
  professional   ProfessionalProfile? @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  fullName       String
  email          String?
  cpf            String?  // @encrypted
  employmentType EmploymentType
  jobTitle       String?
  salaryCents    Int?
  startDate      DateTime
  endDate        DateTime?
  active         Boolean        @default(true)

  payrollLines   OrganizationPayrollEntry[]

