  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  healthPlanId   String?
  healthPlan     HealthPlan?  @relation(fields: [healthPlanId], references: [id], onDelete: SetNull)

  operatorName   String
  ansRegistry    String?
  contractNumber String?
  tissVersion    String       @default("4.01.00")
  active         Boolean      @default(true)

  guides         TissGuide[]
  batches        TissBatch[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model TissGuide {
  id              String          @id @default(cuid())
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orgHealthPlanId String
  orgHealthPlan   OrganizationHealthPlan @relation(fields: [orgHealthPlanId], references: [id], onDelete: Cascade)

  appointmentId   String?
  appointment     Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  professionalId  String
  professional    ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Restrict)
  guideNumber     String?
  guideType       TissGuideType   @default(CONSULTA)
  procedureCode   String          @default("10101012")
  procedureName   String          @default("Consulta em consultorio")
  amountCents     Int

  patientName     String   // @encrypted
  patientCpf      String?  // @encrypted
  cardNumber      String?  // @encrypted

  status          TissGuideStatus @default(DRAFT)
  glosaReason     String?
  glosaAmountCents Int?

  batchId         String?
  batch           TissBatch?      @relation(fields: [batchId], references: [id], onDelete: SetNull)

  serviceDate     DateTime
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([organizationId])
  @@index([orgHealthPlanId])
  @@index([batchId])
  @@index([status])
