  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName       String
  lastName        String
  avatarUrl       String?
  phone           String?  // @encrypted

  // Formation triad (declaratory — no council registry)
  trainingInstitution   String
  personalAnalysisDone  Boolean  @default(false)
  theoreticalStudyDone  Boolean  @default(false)
  clinicalSupervision   Boolean  @default(false)
  yearsOfPractice       Int      @default(0)
  theoreticalLineage    String?
  associations          String[] @default([])
  publications          String?
  otherRegulatedProfession String?

  bio             String?

  // Practice info
  clinicName      String?
  clinicAddress   String?
  clinicCity      String?
  clinicState     String?
  clinicCountry   String?
  clinicZip       String?
  clinicLatitude  Float?
  clinicLongitude Float?

  acceptsTeleconsult  Boolean @default(true)
  acceptsInPerson     Boolean @default(false)
  consultPrice        Float
  currency            String  @default("USD")
  sessionDurationMins Int     @default(50)

  availability    Json?

  verified        Boolean  @default(false)
  verifiedAt      DateTime?
  verifiedBy      String?

  acuraVolunteer  Boolean  @default(false)

  // P8b scheduled volunteer — admin approval (gradual rollout via env flag)
  volunteerScheduledApproved    Boolean   @default(false)
  volunteerScheduledApprovedAt  DateTime?
  volunteerScheduledApprovedBy  String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointments        Appointment[]
  medicalDocuments    MedicalDocument[]
  analysandRecords    AnalysandRecord[]
  availabilitySlots   PsychoanalystAvailabilitySlot[]
  virtualCard         VirtualCard?        @relation("PsychoanalystVirtualCard")
  favorites           PsychoanalystFavorite[]
  reviews             PsychoanalystReview[]

  healthPlans         PsychoanalystHealthPlan[]
  practiceLocations   PracticeLocation[]        @relation("PsychoanalystLocations")
  services            ProviderService[]         @relation("PsychoanalystServices")
  slotAlerts          SlotAvailabilityAlert[]   @relation("PsychoanalystSlotAlerts")
  resources             Resource[]
  resourceCollections   ResourceCollection[]
  humanitarianVolunteers HumanitarianVolunteer[]
  poolContributions       PoolContribution[]
  consultationValidations ConsultationValidation[]

  @@index([userId])
}

model PsychoanalystAvailabilitySlot {
  id               String              @id @default(cuid())
  psychoanalystId  String
  psychoanalyst    PsychoanalystProfile  @relation(fields: [psychoanalystId], references: [id], onDelete: Cascade)

  dayOfWeek        Int
  startTime        String
  endTime          String
  slotDurationMins Int    @default(50)
  slotGapMins      Int    @default(0)
  volunteerOnly    Boolean @default(false)
  isActive         Boolean @default(true)

  @@index([psychoanalystId])
}

// ─────────────────────────────────────────
// INTEGRATIVE THERAPIST PROFILE (PICS / MTCI)
// ─────────────────────────────────────────

model IntegrativeTherapistProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName       String
  lastName        String
  avatarUrl       String?
  phone           String?  // @encrypted

  // PICS — Política Nacional de Práticas Integrativas e Complementares (PNPIC)
  picsPractices   String[] @default([])
  trainingInstitution String
  certifications  String?
  yearsOfPractice Int      @default(0)
  bio             String?

  clinicName      String?
  clinicAddress   String?
  clinicCity      String?
  clinicState     String?
  clinicCountry   String?
  clinicZip       String?
  clinicLatitude  Float?
  clinicLongitude Float?

  acceptsTeleconsult  Boolean @default(true)
  acceptsInPerson     Boolean @default(false)
  consultPrice        Float
  currency            String  @default("USD")
  sessionDurationMins Int     @default(50)

  availability    Json?

  verified        Boolean  @default(false)
  verifiedAt      DateTime?
  verifiedBy      String?

  acuraVolunteer  Boolean  @default(false)

  // P8b scheduled volunteer — admin approval (gradual rollout via env flag)
  volunteerScheduledApproved    Boolean   @default(false)
  volunteerScheduledApprovedAt  DateTime?
  volunteerScheduledApprovedBy  String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointments           Appointment[]
  medicalDocuments       MedicalDocument[]
  clientRecords          IntegrativeClientRecord[]
  availabilitySlots      IntegrativeTherapistAvailabilitySlot[]
  resources              Resource[]
  resourceCollections    ResourceCollection[]
  humanitarianVolunteers HumanitarianVolunteer[]
  virtualCard            VirtualCard?                    @relation("IntegrativeTherapistVirtualCard")
  healthPlans            IntegrativeTherapistHealthPlan[]
  practiceLocations      PracticeLocation[]              @relation("IntegrativeTherapistLocations")
  services               ProviderService[]               @relation("IntegrativeTherapistServices")
  poolContributions      PoolContribution[]
  consultationValidations ConsultationValidation[]
  prescriptions          Prescription[]
  prescriptionTemplates  PrescriptionTemplate[]

  @@index([userId])
}

model IntegrativeTherapistAvailabilitySlot {
  id                    String                      @id @default(cuid())
  integrativeTherapistId String
  integrativeTherapist  IntegrativeTherapistProfile @relation(fields: [integrativeTherapistId], references: [id], onDelete: Cascade)

  dayOfWeek        Int
  startTime        String
  endTime          String
  slotDurationMins Int    @default(50)
  slotGapMins      Int    @default(0)
  isActive         Boolean @default(true)

  @@index([integrativeTherapistId])
}

// ─────────────────────────────────────────
// MEDICATIONS (FIX: two separate flows)
// ─────────────────────────────────────────

model Medication {
  id              String         @id @default(cuid())
  patientId       String
  patient         PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  name            String         // @encrypted — PHI
  dosage          String?        // @encrypted — PHI
  frequency       String?        // @encrypted — PHI
  startDate       DateTime?
  endDate         DateTime?
  prescribedBy    String?
  notes           String?        // @encrypted

  // THE FIX: separates clinical from purchase
  flow            MedicationFlow @default(CLINICAL)

  // PURCHASE flow: linked to DrugCatalog + CMED reference at save time
  drugCatalogId       String?
  referencePriceCents Int?

  active          Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([patientId])
  @@index([flow])  // allows querying clinical vs purchase separately
}

// ─────────────────────────────────────────
// APPOINTMENTS + SCHEDULING
// ─────────────────────────────────────────

model AvailabilitySlot {
  id               String              @id @default(cuid())
  professionalId   String
  professional     ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  dayOfWeek        Int    // 0=Sunday, 6=Saturday
  startTime        String // "09:00"
  endTime          String // "17:00"
  slotDurationMins Int    @default(30)
  slotGapMins      Int    @default(0)
  volunteerOnly    Boolean @default(false)
  isActive         Boolean @default(true)

  @@index([professionalId])
}

model Appointment {
  id               String              @id @default(cuid())
  patientId        String
  patient          PatientProfile      @relation(fields: [patientId], references: [id])
  providerType     ProviderType        @default(HEALTH)
  professionalId   String?
  professional     ProfessionalProfile? @relation(fields: [professionalId], references: [id])
  psychoanalystId  String?
  psychoanalyst    PsychoanalystProfile? @relation(fields: [psychoanalystId], references: [id])
  integrativeTherapistId String?
  integrativeTherapist   IntegrativeTherapistProfile? @relation(fields: [integrativeTherapistId], references: [id])

  scheduledAt      DateTime
  durationMins     Int                 @default(30)
  type             AppointmentType     @default(TELECONSULT)
  status           AppointmentStatus   @default(PENDING)

  // Teleconsult
  videoChannel     AppointmentVideoChannel @default(DAILY)
  meetingUrl       String?
  meetingRoomId    String?

  // Payment
  priceAmount      Int     // in cents
  currency         String  @default("USD")
  stripePaymentId  String?  @unique
  paidAt           DateTime?

  // Clinical
  chiefComplaint   String? // @encrypted — PHI
  notes            String? // @encrypted — PHI

  // Reminders sent
  reminder24hSent  Boolean @default(false)
  reminder1hSent   Boolean @default(false)
  reviewRequestSent Boolean @default(false)
  remindersEpoch   Int     @default(0)

  bookingSource    String?  // patient_panel | public_profile | public_search | eap_corporate

  // Corporate EAP (employer-funded psychology sessions)
  employerWorkforceMemberId String?
  employerWorkforceMember   EmployerWorkforceMember? @relation(fields: [employerWorkforceMemberId], references: [id], onDelete: SetNull)

  // Dental clinic — optional chair assignment
  dentalChairId    String?
  dentalChair      DentalChair? @relation(fields: [dentalChairId], references: [id], onDelete: SetNull)

  cancelledAt      DateTime?
  cancelledBy      String?
  cancelReason     String?

  patientConfirmedAt DateTime?
  patientJoinedAt    DateTime?
  professionalJoinedAt DateTime?

  adminProblemAt   DateTime?
  adminProblemNote String?
  adminProblemById String?

  googleCalendarEventId String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  documents        MedicalDocument[]
  paymentRefunds   PaymentRefund[]
  professionalPayout ConsultationProfessionalPayout?
  tissGuides       TissGuide[]
  orgLedgerEntries OrganizationLedgerEntry[]
  orgSurveyResponses OrganizationSurveyResponse[]

  @@index([patientId])
  @@index([professionalId])
  @@index([psychoanalystId])
  @@index([integrativeTherapistId])
  @@index([providerType])
  @@index([scheduledAt])
  @@index([status])
  // Partial unique indexes on (providerId, scheduledAt) for CONFIRMED|PENDING — see migration 20260712160000_appointment_active_slot_unique
}

// Stripe webhook idempotency — one row per event.id after side effects complete.
model ProcessedStripeEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique
  type        String
  status      String   // PROCESSED | FAILED
  error       String?
  processedAt DateTime @default(now())
}

model PaymentRefund {
  id              String   @id @default(cuid())
  paymentIntentId String
  stripeRefundId  String?  @unique
  reason          String
  amountCents     Int?
  currency        String?
  status          String   // SUCCEEDED | ALREADY_REFUNDED | FAILED
  triggeredBy     String   // AUTO_SLOT_TAKEN | AUTO_WEBHOOK_FAIL | PATIENT_CANCEL | JIT_ORPHAN | JIT_QUEUE | OTHER
  appointmentId   String?
  appointment     Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  pharmacyOrderId String?
  pharmacyOrder   PharmacyOrder? @relation(fields: [pharmacyOrderId], references: [id], onDelete: SetNull)
  userId          String?
  user            User? @relation("PaymentRefundUser", fields: [userId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())

  @@index([paymentIntentId])
  @@index([pharmacyOrderId])
  @@index([createdAt])
}

enum ConsultationPayoutStatus {
  PENDING
  TRANSFERRED
  CANCELLED
  FAILED
}

// Scheduled Connect transfer of the professional share (85%) after refund/cancel window.
model ConsultationProfessionalPayout {
  id                    String                   @id @default(cuid())
  appointmentId         String                   @unique
  appointment           Appointment              @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  professionalProfileId String
  professionalProfile   ProfessionalProfile      @relation(fields: [professionalProfileId], references: [id], onDelete: Cascade)
  stripePaymentIntentId String
  grossCents            Int
  netCents              Int
  applicationFeeCents   Int
  currency              String
  connectAccountId      String
  transferEligibleAt    DateTime
  status                ConsultationPayoutStatus @default(PENDING)
  stripeTransferId      String?                  @unique
  transferredAt         DateTime?
  cancelledAt           DateTime?
  failureReason         String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([status, transferEligibleAt])
  @@index([stripePaymentIntentId])
}

// ─────────────────────────────────────────
// MEDICAL DOCUMENTS + CARDS
// ─────────────────────────────────────────

model MedicalDocument {
  id               String              @id @default(cuid())
  patientId        String?
  patient          PatientProfile?     @relation(fields: [patientId], references: [id])
  patientRecordId  String?
  patientRecord    PatientRecord?      @relation(fields: [patientRecordId], references: [id])
  professionalId   String?
  professional     ProfessionalProfile? @relation(fields: [professionalId], references: [id])
  psychoanalystId  String?
  psychoanalyst    PsychoanalystProfile? @relation(fields: [psychoanalystId], references: [id])
  analysandRecordId String?
  analysandRecord  AnalysandRecord?    @relation(fields: [analysandRecordId], references: [id])
  integrativeTherapistId String?
  integrativeTherapist   IntegrativeTherapistProfile? @relation(fields: [integrativeTherapistId], references: [id])
  integrativeClientRecordId String?
  integrativeClientRecord   IntegrativeClientRecord? @relation(fields: [integrativeClientRecordId], references: [id])
  appointmentId    String?
  appointment      Appointment?        @relation(fields: [appointmentId], references: [id])

  type             DocumentType
  recordKind       ClinicalRecordKind @default(OTHER)
  categoryId       String?
  category         Category?    @relation(fields: [categoryId], references: [id])
  title            String       // @encrypted
  content          String?      @db.Text  // @encrypted — PHI
  fileUrl          String?      // S3 URL — @encrypted

  // When this record is a COPY of a document shared by a patient (4D/3D-2),
  // this points to the original shared document (to prevent duplicates).
  sourceDocumentId String?

  // Sharing
  sharedRecords    SharedRecord[]

  // Digital signature via Lacuna (same flow as Prescription)
  signatureSessionId String?
  signatureStatus    String?   // PENDING | SIGNED | CANCELLED | ERROR
  signedFileUrl      String?   // S3 key of signed PDF
  signedAt           DateTime?
  digitalSignature   String?
  patientNotifiedAt  DateTime?
  whatsappNotifiedAt DateTime?
  whatsappNotifyStatus String? // SENT | FAILED | NO_PHONE | SKIPPED

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  prescriptions    Prescription[]

  @@index([patientId])
  @@index([patientRecordId])
  @@index([analysandRecordId])
  @@index([integrativeClientRecordId])
  @@index([psychoanalystId])
  @@index([integrativeTherapistId])
  @@index([type])
  @@index([categoryId])
  @@index([recordKind])
}

model SharedRecord {
  id               String           @id @default(cuid())
  documentId       String
  document         MedicalDocument  @relation(fields: [documentId], references: [id])
  patientId        String
  patient          PatientProfile   @relation(fields: [patientId], references: [id])

  // Who can access
  sharedWithEmail  String?   // external share
  sharedWithUserId String?   // internal share

  // Direction of the share (Phase 4D)
  sharedByUserId            String?              // NEW — who shared it (patient, when patient->doctor)
  sharedWithProfessionalId  String?              // NEW — recipient professional (patient->doctor)
  sharedWithProfessional    ProfessionalProfile? @relation("DocsSharedWithProfessional", fields: [sharedWithProfessionalId], references: [id]) // NEW

  accessToken      String    @unique @default(cuid()) // for link sharing
  expiresAt        DateTime? // public links: always set; legacy null uses createdAt + default TTL
  viewedAt         DateTime?
  isPublicLink     Boolean   @default(false) // only true for token-based external shares
  viewCount        Int       @default(0)
  maxViews         Int       @default(50)
  revokedAt        DateTime?
  viewPinHash      String?   // optional bcrypt PIN for public link access

  createdAt        DateTime  @default(now())

  @@index([patientId])
  @@index([accessToken])
  @@index([sharedWithProfessionalId])
}

// Consent-based patient ↔ medical professional link (prescribe/search without full chart read).
model PatientProfessionalLink {
  id                 String                        @id @default(cuid())
  patientUserId      String
  professionalUserId String
  status             PatientProfessionalLinkStatus @default(PENDING)
  requestedBy        String                        // "PROFESSIONAL" | "PATIENT"
  createdAt          DateTime                      @default(now())
  respondedAt        DateTime?

  patient      User @relation("PatientProfessionalLinkPatient", fields: [patientUserId], references: [id], onDelete: Cascade)
  professional User @relation("PatientProfessionalLinkProfessional", fields: [professionalUserId], references: [id], onDelete: Cascade)

  @@unique([patientUserId, professionalUserId])
  @@index([professionalUserId, status])
  @@index([patientUserId, status])
}

// Patient report: "I don't know this professional" after unsolicited emission.
model ProfessionalEmissionReport {
  id                 String   @id @default(cuid())
  patientUserId      String
  professionalUserId String
  resourceType       String   // PRESCRIPTION | EXAM_REQUEST | ...
  resourceId         String
  createdAt          DateTime @default(now())

  patient      User @relation("EmissionReportPatient", fields: [patientUserId], references: [id], onDelete: Cascade)
  professional User @relation("EmissionReportProfessional", fields: [professionalUserId], references: [id], onDelete: Cascade)

  @@index([professionalUserId])
  @@index([patientUserId])
}

model Prescription {
  id               String              @id @default(cuid())
  documentId       String?
  document         MedicalDocument?    @relation(fields: [documentId], references: [id])
  professionalId   String?
  professional     ProfessionalProfile? @relation(fields: [professionalId], references: [id])
  integrativeTherapistId String?
  integrativeTherapist   IntegrativeTherapistProfile? @relation(fields: [integrativeTherapistId], references: [id])

  // @encrypted — all PHI
  medications      Json    // [{name, dosage, frequency, duration, instructions}]
  instructions     String? // @encrypted
  validUntil       DateTime?
  digitalSignature String? // professional's signature reference (e.g. Lacuna session id)

  // Digital signature via Lacuna Rest PKI Core (cloud certificate / PAdES)
  signatureSessionId String?   // Rest PKI Core signature session id
  signatureStatus    String?   // PENDING | SIGNED | CANCELLED | ERROR
  signedFileUrl      String?   // S3 key of the signed PDF
  signedAt           DateTime?
  patientNotifiedAt  DateTime?
  whatsappNotifiedAt DateTime?
  whatsappNotifyStatus String? // SENT | FAILED | NO_PHONE | SKIPPED

  pharmacyAccessToken  String?   @unique
  pharmacyDispensedAt  DateTime?
  pharmacyDispensedStoreId String?
  pharmacyDispensedStore   PharmacyStore? @relation(fields: [pharmacyDispensedStoreId], references: [id], onDelete: SetNull)

  pharmacyOrders       PharmacyOrder[]
  pharmacyPrescriptionToken PharmacyPrescriptionToken?

  /// SIMPLE | NRB | RCE — tipo regulatório do receituário (Portaria 344/98)
  prescriptionFormKind   String?
  prescriptionPackageId  String?
  prescriptionPackage    PrescriptionPackage? @relation(fields: [prescriptionPackageId], references: [id], onDelete: SetNull)
  /// Numeração SNCR (Notificação de Receita ou RCE)
  sncrReceiptNumber      String?
  sncrReceiptType        String?
  sncrIssuedAt           DateTime?
  issuedViaTelemedicine  Boolean @default(false)

  createdAt        DateTime @default(now())

  @@index([professionalId])
  @@index([integrativeTherapistId])
  @@index([prescriptionPackageId])
  @@index([prescriptionFormKind])
}

model PrescriptionPackage {
  id             String   @id @default(cuid())
  professionalId String
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  prescriptions  Prescription[]
  createdAt      DateTime @default(now())

  @@index([professionalId])
}

/// Token OAuth Gov.br / SNCR por profissional (access token criptografado na aplicação)
model SncrOAuthCredential {
  id             String   @id @default(cuid())
  professionalId String   @unique
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  accessToken    String   @db.Text
  expiresAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

/// Pool local de numerações SNCR ainda não vinculadas a receitas
model SncrNumberPool {
  id             String   @id @default(cuid())
  professionalId String
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  receiptType    String
  numbers        Json
  updatedAt      DateTime @updatedAt

  @@unique([professionalId, receiptType])
  @@index([professionalId])
}

// ─────────────────────────────────────────
// MESSAGING
// ─────────────────────────────────────────

model Message {
  id          String   @id @default(cuid())
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId  String
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id])

  content     String   @db.Text  // @encrypted — may contain PHI
  readAt      DateTime?
  deletedAt   DateTime?

  createdAt   DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
}

// ─────────────────────────────────────────
// PAYMENTS + SUBSCRIPTIONS
// ─────────────────────────────────────────

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id])

  stripeCustomerId     String   @unique
  stripeSubscriptionId String?  @unique
  stripePriceId        String?

  status               String   // active, cancelled, past_due, trialing
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean  @default(false)

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ─────────────────────────────────────────
// PROFESSIONAL VIRTUAL CARD
// ─────────────────────────────────────────

model VirtualCard {
  id              String                @id @default(cuid())
  professionalId  String?               @unique
  professional    ProfessionalProfile?  @relation("ProfessionalVirtualCard", fields: [professionalId], references: [id])
  psychoanalystId String?               @unique
  psychoanalyst   PsychoanalystProfile? @relation("PsychoanalystVirtualCard", fields: [psychoanalystId], references: [id])
  integrativeTherapistId String?               @unique
  integrativeTherapist   IntegrativeTherapistProfile? @relation("IntegrativeTherapistVirtualCard", fields: [integrativeTherapistId], references: [id])

  slug            String                @unique
  specialtySlug   String                @default("")
  citySlug        String                @default("")
  headline        String?
  website         String?
  googleBusinessUrl String?
  socialLinks     Json?
  whatsappNumber  String?
  coverImageUrl   String?
  galleryImages   Json?
  videoUrl        String?
  themePreset     String                @default("default")
  accentColor     String?
  contentBlocks   Json?
  isPublic        Boolean               @default(false)

  profileEvents   PublicProfileEvent[]

  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([specialtySlug, citySlug])
}

enum PublicProfileEventType {
  VIEW
  BOOK_CLICK
}

model PublicProfileEvent {
  id            String                 @id @default(cuid())
  virtualCardId String
  virtualCard   VirtualCard            @relation(fields: [virtualCardId], references: [id], onDelete: Cascade)
  type          PublicProfileEventType
  source        String?
  createdAt     DateTime               @default(now())

  @@index([virtualCardId, createdAt])
  @@index([virtualCardId, type, createdAt])
}

// ─────────────────────────────────────────
// HEALTH PLANS (convênios) — public search filter
// ─────────────────────────────────────────

model HealthPlan {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  sortOrder Int      @default(0)

  professionals  ProfessionalHealthPlan[]
  psychoanalysts PsychoanalystHealthPlan[]
  integrativeTherapists IntegrativeTherapistHealthPlan[]
  organizations  OrganizationHealthPlan[]

  @@index([sortOrder])
}

model ProfessionalHealthPlan {
  professionalId String
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  healthPlanId   String
  healthPlan     HealthPlan          @relation(fields: [healthPlanId], references: [id], onDelete: Cascade)

  allowedWeekdays Int[] @default([]) // empty = all days the provider is open
  minLeadDays     Int   @default(0)  // minimum booking advance (days)

  @@id([professionalId, healthPlanId])
  @@index([healthPlanId])
}

model PsychoanalystHealthPlan {
  psychoanalystId String
  psychoanalyst   PsychoanalystProfile @relation(fields: [psychoanalystId], references: [id], onDelete: Cascade)
  healthPlanId    String
  healthPlan      HealthPlan           @relation(fields: [healthPlanId], references: [id], onDelete: Cascade)

  allowedWeekdays Int[] @default([])
  minLeadDays     Int   @default(0)

  @@id([psychoanalystId, healthPlanId])
  @@index([healthPlanId])
}

model IntegrativeTherapistHealthPlan {
  integrativeTherapistId String
  integrativeTherapist   IntegrativeTherapistProfile @relation(fields: [integrativeTherapistId], references: [id], onDelete: Cascade)
  healthPlanId           String
  healthPlan             HealthPlan                  @relation(fields: [healthPlanId], references: [id], onDelete: Cascade)

  allowedWeekdays Int[] @default([])
  minLeadDays     Int   @default(0)

  @@id([integrativeTherapistId, healthPlanId])
  @@index([healthPlanId])
}

// ─────────────────────────────────────────
// PRACTICE LOCATIONS + SERVICES (public profile)
// ─────────────────────────────────────────

model PracticeLocation {
  id              String                @id @default(cuid())
  professionalId  String?
  professional    ProfessionalProfile?  @relation("ProfessionalLocations", fields: [professionalId], references: [id], onDelete: Cascade)
  psychoanalystId String?
  psychoanalyst   PsychoanalystProfile? @relation("PsychoanalystLocations", fields: [psychoanalystId], references: [id], onDelete: Cascade)
  integrativeTherapistId String?
  integrativeTherapist   IntegrativeTherapistProfile? @relation("IntegrativeTherapistLocations", fields: [integrativeTherapistId], references: [id], onDelete: Cascade)

  name            String
  address         String
  city            String
  state           String?
  country         String?
  zip             String?
  latitude        Float?
  longitude       Float?
  isPrimary       Boolean  @default(false)
  sortOrder       Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([professionalId])
  @@index([psychoanalystId])
  @@index([integrativeTherapistId])
}

model ProviderService {
  id              String                @id @default(cuid())
  professionalId  String?
  professional    ProfessionalProfile?  @relation("ProfessionalServices", fields: [professionalId], references: [id], onDelete: Cascade)
  psychoanalystId String?
  psychoanalyst   PsychoanalystProfile? @relation("PsychoanalystServices", fields: [psychoanalystId], references: [id], onDelete: Cascade)
  integrativeTherapistId String?
  integrativeTherapist   IntegrativeTherapistProfile? @relation("IntegrativeTherapistServices", fields: [integrativeTherapistId], references: [id], onDelete: Cascade)

  name            String
  description     String?
  priceCents      Int?
  currency        String   @default("BRL")
  isReturnService Boolean  @default(false)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

