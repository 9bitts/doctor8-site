// DRUG CATALOG (medication reference database)
// This is the SEARCHABLE CATALOG of drugs (like Memed's database).
// It is NOT patient data — it's a shared reference list the doctor
// searches when writing a prescription. No PHI here.
// (Note: the existing "Medication" model is the patient's own list —
//  this is different and intentionally named DrugCatalog to avoid collision.)
// ─────────────────────────────────────────
model DrugCatalog {
  id              String   @id @default(cuid())

  // Display + search
  name            String   // commercial/brand name, e.g. "Amoxil"
  activeIngredient String  // e.g. "Amoxicillin" / "Amoxicilina"
  presentation    String   // e.g. "500mg capsule, box of 21"
  manufacturer    String?  // e.g. "GSK"

  // Classification
  country         String   @default("BR")  // "BR", "US", "EU" ...
  category        String?  // e.g. "Antibiotic", "Analgesic"
  controlled      Boolean  @default(false) // tarja preta / controlled substance
  prescriptionType String? // "OTC", "RED_STRIPE", "BLACK_STRIPE", "RX"

  // Normalized lowercase fields for fast case-insensitive search
  searchName      String   // lowercase of name
  searchIngredient String  // lowercase of activeIngredient
  searchPresentation String? // lowercase presentation without accents (CMED search)

  // CMED-specific (optional — null for ANVISA/VE/US legacy rows)
  ggremCode           String? @unique // ANVISA CÓDIGO GGREM
  externalCode        String? // country registry code (e.g. CO CUM expedientecum-consecutivocum)
  pharmaceuticalForm  String? // e.g. Comprimido, Xarope (frasco)
  dosage              String? // e.g. 10 MG/ML — extracted from presentation

  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  pharmacyInventoryItems PharmacyStoreInventoryItem[]

  @@unique([country, externalCode])
  @@index([searchName])
  @@index([searchIngredient])
  @@index([searchPresentation])
  @@index([ggremCode])
  @@index([externalCode])
  @@index([country])
  @@index([active])

  buyingClub BuyingClub?

  drugLeaflets DrugLeaflet[]
}

// ─────────────────────────────────────────
// DRUG LEAFLET (ANVISA bula sections — reference, not PHI)
// Indexed by GGREM and/or normalized active ingredient for prescription lookup.
// ─────────────────────────────────────────
model DrugLeaflet {
  id                  String   @id @default(cuid())

  ggremCode           String?  @unique
  activeIngredientKey String
  activeIngredient    String
  productName         String?

  country             String   @default("BR")
  anvisaProcessNumber String?
  manufacturer        String?
  pdfUrl              String?
  externalUrl         String?

  /// [{ key, title, content, defaultOpen? }]
  sections            Json
  posologyExcerpt     String?  @db.Text
  source              String   @default("curated")

  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  drugCatalog         DrugCatalog? @relation(fields: [ggremCode], references: [ggremCode], onDelete: SetNull)

  @@index([activeIngredientKey])
  @@index([country, activeIngredientKey])
  @@index([active])
}

// ─────────────────────────────────────────
// CBHPM CATALOG (exam / procedure reference — CBHPM 2012)
// Searchable list for exam requests. Not PHI.
// ─────────────────────────────────────────
model CbhpmCatalog {
  id          String   @id @default(cuid())
  code        String   @unique   // e.g. "4.03.01.84-2"
  name        String             // e.g. "Ferro sérico, dosagem"
  chapter     String             // e.g. "4" (diagnostic procedures)
  groupName   String?            // e.g. "BIOQUÍMICA"
  searchName  String             // lowercase normalized name
  searchCode  String             // digits only for partial code search
  edition     String   @default("2012")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([searchName])
  @@index([searchCode])
  @@index([chapter])
  @@index([active])
}

// ─────────────────────────────────────────
// CID-10 CATALOG (Brazilian DATASUS — diagnosis codes)
// Searchable by code (e.g. A010) or description. Not PHI.
// ─────────────────────────────────────────
model Cid10Catalog {
  id                String   @id @default(cuid())
  code              String   @unique   // e.g. "A010" or "M8000/0"
  description       String             // e.g. "Febre tifóide"
  searchDescription String             // lowercase normalized description
  searchCode        String             // uppercase alphanumeric only
  source            String   @default("CID10") // CID10 | CID-O
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([searchDescription])
  @@index([searchCode])
  @@index([active])
  @@index([source])
}

// ─────────────────────────────────────────
// BUYING CLUB — collective medication purchase groups
// One club per DrugCatalog entry. Patients join to get group discounts.
// ─────────────────────────────────────────
model BuyingClub {
  id            String   @id @default(cuid())
  drugCatalogId String   @unique
  drugCatalog   DrugCatalog @relation(fields: [drugCatalogId], references: [id], onDelete: Cascade)
  shareToken    String   @unique @default(cuid())
  status        String   @default("OPEN") // OPEN, READY, CLOSED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  members       BuyingClubMember[]

  @@index([status])
}

model BuyingClubMember {
  id           String     @id @default(cuid())
  buyingClubId String
  buyingClub   BuyingClub @relation(fields: [buyingClubId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  active       Boolean    @default(true)
  joinedAt     DateTime   @default(now())
  leftAt       DateTime?

  @@unique([buyingClubId, userId])
  @@index([buyingClubId, active])
  @@index([userId])
}

model ResourceCollection {
  id                     String                      @id @default(cuid())
  professionalId         String?
  professional           ProfessionalProfile?        @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  psychoanalystId        String?
  psychoanalyst          PsychoanalystProfile?       @relation(fields: [psychoanalystId], references: [id], onDelete: Cascade)
  integrativeTherapistId String?
  integrativeTherapist   IntegrativeTherapistProfile? @relation(fields: [integrativeTherapistId], references: [id], onDelete: Cascade)
  title                  String                      // encrypted
  description            String?                     // encrypted
  category               String                      @default("general")
  active                 Boolean                     @default(true)
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  resources              Resource[]

  @@index([professionalId])
  @@index([psychoanalystId])
  @@index([integrativeTherapistId])
}

model Resource {
  id              String               @id @default(cuid())
  professionalId  String?
  professional    ProfessionalProfile? @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  psychoanalystId String?
  psychoanalyst   PsychoanalystProfile? @relation(fields: [psychoanalystId], references: [id], onDelete: Cascade)
  integrativeTherapistId String?
  integrativeTherapist   IntegrativeTherapistProfile? @relation(fields: [integrativeTherapistId], references: [id], onDelete: Cascade)
  collectionId    String?
  collection      ResourceCollection?  @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  title           String               // encrypted
  content         String?              // encrypted — description/notes
  url             String?              // YouTube link (plain — not PHI)
  fileUrl         String?              // encrypted S3 key
  category        String               @default("general")
  contentType     String               @default("link") // link | file | text
  sourcePackId    String?              // platform pack id when imported
  active          Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  shares          ResourceShare[]
  analysandShares AnalysandResourceShare[]
  integrativeShares IntegrativeResourceShare[]

  @@index([professionalId])
  @@index([psychoanalystId])
  @@index([integrativeTherapistId])
  @@index([collectionId])
  @@index([category])
}

model ResourceShare {
  id              String        @id @default(cuid())
  resourceId      String
  resource        Resource      @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  patientRecordId String
  patientRecord   PatientRecord @relation(fields: [patientRecordId], references: [id], onDelete: Cascade)
  sharedAt        DateTime      @default(now())
  viewedAt        DateTime?
  viewCount       Int           @default(0)

  @@unique([resourceId, patientRecordId])
}

model AnalysandResourceShare {
  id                String          @id @default(cuid())
  resourceId        String
  resource          Resource        @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  analysandRecordId String
  analysandRecord   AnalysandRecord @relation(fields: [analysandRecordId], references: [id], onDelete: Cascade)
  sharedAt          DateTime        @default(now())
  viewedAt          DateTime?
  viewCount         Int             @default(0)

  @@unique([resourceId, analysandRecordId])
}

model IntegrativeResourceShare {
  id                      String                  @id @default(cuid())
  resourceId              String
  resource                Resource                @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  integrativeClientRecordId String
  integrativeClientRecord IntegrativeClientRecord @relation(fields: [integrativeClientRecordId], references: [id], onDelete: Cascade)
  sharedAt                DateTime                @default(now())
  viewedAt                DateTime?
  viewCount               Int                     @default(0)

  @@unique([resourceId, integrativeClientRecordId])
}

// ─────────────────────────────────────────
// JUST-IN-TIME — Plantão Online
// ─────────────────────────────────────────

model JitSession {
  id              String              @id @default(cuid())
  professionalId  String
  professional    ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  mode            JitMode             @default(QUEUE)
  status          JitSessionStatus    @default(OFFLINE)
  specialty       String              // e.g. "Medicina Geral", "Psicologia"

  // Pricing — 0 = gratuito
  priceAmount     Int                 @default(0)  // in cents
  currency        String              @default("BRL")
  isFree          Boolean             @default(true)

  // Queue settings
  maxQueueSize            Int         @default(50)
  estimatedMinutesPerPatient Int      @default(20)
  noShowTimeoutSeconds    Int         @default(120) // 2 minutes

  // Event link (optional — for emergency events like RS floods)
  jitEventId      String?
  jitEvent        JitEvent?           @relation(fields: [jitEventId], references: [id])

  queue           JitQueue[]

  lastHeartbeatAt DateTime?           // updated while professional is active on plantão

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([professionalId])
  @@index([status])
  @@index([specialty])
  @@index([lastHeartbeatAt])
}

model JitQueue {
  id              String          @id @default(cuid())
  sessionId       String
  session         JitSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Patient — must have account (login required)
  patientUserId   String
  patientUser     User            @relation("JitQueuePatient", fields: [patientUserId], references: [id])

  status          JitQueueStatus  @default(WAITING)
  position        Int             // position in queue (recalculated on each change)
  specialty       String          // what the patient needs

  // Timestamps
  enteredAt       DateTime        @default(now())
  calledAt        DateTime?       // when professional clicked "call next"
  expiresAt       DateTime?       // calledAt + noShowTimeoutSeconds
  startedAt       DateTime?       // when patient clicked "enter"
  endedAt         DateTime?       // when session ended

  // Video room
  meetingUrl      String?         // Daily.co room URL
  meetingRoomId   String?

  // Payment
  paymentId       String?         @unique
  payment         JitPayment?     @relation(fields: [paymentId], references: [id])

  employerWorkforceMemberId String?
  employerWorkforceMember   EmployerWorkforceMember? @relation(fields: [employerWorkforceMemberId], references: [id], onDelete: SetNull)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([sessionId])
  @@index([patientUserId])
  @@index([status])
}

model JitPayment {
  id                String    @id @default(cuid())
  amount            Int       // in cents
  currency          String    @default("BRL")
  stripePaymentId   String?   @unique
  paidAt            DateTime?
  status            String    @default("pending") // pending | paid | refunded | failed

  queueEntry        JitQueue?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model JitEvent {
  id          String    @id @default(cuid())
  name        String    // e.g. "Ação RS — Enchentes 2024"
  description String?
  startAt     DateTime
  endAt       DateTime?

  // Force all sessions in this event to be free
  forceFree   Boolean   @default(true)

  // Which specialties are part of this event
  specialties String[]  @default([])

  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  sessions    JitSession[]
}

// ─────────────────────────────────────────
// HUMANITARIAN CARE — pooled queues (e.g. Venezuela earthquake relief)
// Patients join a specialty pool; dispatcher assigns next free volunteer.
// ─────────────────────────────────────────

model HumanitarianCampaign {
  id                       String    @id @default(cuid())
  slug                     String    @unique
  name                     String
  description              String?
  region                   String?   @db.VarChar(2)
  active                   Boolean   @default(true)
  startAt                  DateTime  @default(now())
  endAt                    DateTime?

  noShowTimeoutSeconds     Int       @default(180)
  estimatedMinutesPerPatient Int     @default(15)

  pools                    HumanitarianPool[]
  volunteers               HumanitarianVolunteer[]
  angels                   HumanitarianAngel[]
  entries                  HumanitarianQueueEntry[]
  intakes                  HumanitarianIntake[]
  angelFollowUps           HumanitarianAngelFollowUp[]
  angelAssignments         HumanitarianAngelAssignment[]
  volunteerOnlineAlerts    HumanitarianVolunteerOnlineAlert[]
  angelMissions            AngelMission[]
  angelAnnouncements       AngelAnnouncement[]

  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([active])
  @@index([slug])
}

model HumanitarianIntake {
  id                  String                   @id @default(cuid())
  campaignId          String
  campaign            HumanitarianCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  patientUserId       String
  patientUser         User                     @relation("HumanitarianIntakePatient", fields: [patientUserId], references: [id], onDelete: Cascade)

  triageData          Json?
  triageCompletedAt   DateTime?
  computedPriority    HumanitarianPriority?
  triageFlags         String[]                 @default([])
  forceMedicalPool    Boolean                  @default(false)

  identificationData  Json?
  serviceTypes        String[]                 @default([])
  specialtyData       Json?
  basicNeedsData      Json?
  consentAt           DateTime?
  telemedicineTcleAt  DateTime?
  telemedicineTcleVersion String?
  angelContactConsentAt DateTime?
  angelContactConsentVersion String?
  additionalNotes     String?

  status              HumanitarianIntakeStatus @default(TRIAGE_ONLY)

  entries             HumanitarianQueueEntry[]

  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@unique([campaignId, patientUserId])
  @@index([campaignId, status])
  @@index([campaignId, computedPriority])
  @@index([patientUserId])
}

model HumanitarianPool {
  id           String               @id @default(cuid())
  campaignId   String
  campaign     HumanitarianCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  slug         String               // medico | psicologo | psicanalista | terapeuta_integrativo | fisioterapeuta | nutricionista | cuidados_paliativos
  labelEs      String
  labelPt      String
  labelEn      String
  maxWaiting   Int                  @default(500)
  sortOrder    Int                  @default(0)

  entries      HumanitarianQueueEntry[]
  volunteers   HumanitarianVolunteer[]

  @@unique([campaignId, slug])
  @@index([campaignId])
}

model HumanitarianVolunteer {
  id              String                      @id @default(cuid())
  campaignId      String
  campaign        HumanitarianCampaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  poolId          String
  pool            HumanitarianPool            @relation(fields: [poolId], references: [id], onDelete: Cascade)

  userId          String
  user            User                        @relation("HumanitarianVolunteer", fields: [userId], references: [id], onDelete: Cascade)
  providerType    ProviderType
  professionalId  String?
  professional    ProfessionalProfile?        @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  psychoanalystId String?
  psychoanalyst   PsychoanalystProfile?       @relation(fields: [psychoanalystId], references: [id], onDelete: Cascade)
  integrativeTherapistId String?
  integrativeTherapist   IntegrativeTherapistProfile? @relation(fields: [integrativeTherapistId], references: [id], onDelete: Cascade)

  status          HumanitarianVolunteerStatus @default(OFFLINE)
  lastSeenAt      DateTime?
  lastAssignedAt  DateTime?
  currentEntryId  String?                     @unique

  entries         HumanitarianQueueEntry[]

  @@unique([campaignId, userId, poolId])
  @@index([poolId, status])
  @@index([userId])
}

/// Patient opt-in: notify when the first volunteer goes online on a campaign (AGD-35).
model HumanitarianVolunteerOnlineAlert {
  id             String               @id @default(cuid())
  campaignId     String
  campaign       HumanitarianCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId         String
  user           User                 @relation("HumanitarianVolunteerOnlineAlert", fields: [userId], references: [id], onDelete: Cascade)
  active         Boolean              @default(true)
  lastNotifiedAt DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([campaignId, userId])
  @@index([campaignId, active])
}

model HumanitarianQueueEntry {
  id              String                   @id @default(cuid())
  campaignId      String
  campaign        HumanitarianCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  poolId          String
  pool            HumanitarianPool         @relation(fields: [poolId], references: [id], onDelete: Cascade)

  patientUserId   String
  patientUser     User                     @relation("HumanitarianQueuePatient", fields: [patientUserId], references: [id], onDelete: Cascade)

  status          HumanitarianQueueStatus  @default(WAITING)
  priority        HumanitarianPriority     @default(ROUTINE)
  position        Int

  volunteerId     String?
  volunteer       HumanitarianVolunteer?   @relation(fields: [volunteerId], references: [id], onDelete: SetNull)

  chiefComplaint  String?

  intakeId        String?
  intake          HumanitarianIntake?      @relation(fields: [intakeId], references: [id], onDelete: SetNull)

  enteredAt       DateTime                 @default(now())
  lastSeenAt      DateTime?
  calledAt        DateTime?
  expiresAt       DateTime?
  startedAt       DateTime?
  endedAt         DateTime?

  meetingUrl      String?
  meetingRoomId   String?

  completionChannel HumanitarianCompletionChannel?

  adminRemovedById    String?
  adminRemovedAt      DateTime?
  adminRemovalReason  String?

  adminProblemAt      DateTime?
  adminProblemNote    String?
  adminProblemById    String?

  angelFollowUps  HumanitarianAngelFollowUp[]

  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([poolId, status, position])
  @@index([poolId, status, priority, position])
  @@index([patientUserId, status])
  @@index([campaignId])
}

// ─────────────────────────────────────────
// ANGEL — lay humanitarian follow-up volunteers (Acura / Doctor8)
// ─────────────────────────────────────────

model AngelProfile {
  id              String              @id @default(cuid())
  userId          String              @unique
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName       String
  lastName        String
  phone           String?             // @encrypted
  profession      String?
  volunteerHelp   String?
  languages       String[]            @default([])
  motivation      String?
  preferredCampaignSlug String?

  // Matching signals / multi-track program (Onda 1)
  skills          String[]            @default([])
  city            String?
  hasVehicle      Boolean             @default(false)
  availabilityNote String?
  availabilityStatus AngelAvailabilityStatus @default(AVAILABLE)
  pausedUntil     DateTime?
  weeklyCapacity  Int?

  // Screening workflow (proportional to track risk)
  screeningStatus AngelScreeningStatus @default(NOT_SUBMITTED)
  screeningNotes  String?
  screeningReviewedAt DateTime?
  screeningReviewedById String?

  approvalStatus  AngelApprovalStatus @default(PENDING)
  approvedAt      DateTime?
  approvedById    String?
  rejectionReason String?

  trackEnrollments AngelTrackEnrollment[]
  trainingExemptions AngelTrackTrainingExemption[]
  missionSignups   AngelMissionSignup[]
  hourLogs         AngelHourLog[]
  milestones       AngelMilestone[]
  volunteerCertificate AngelVolunteerCertificate?
  wellbeingCheckins AngelWellbeingCheckin[]
  supervisionNotes  AngelSupervisionNote[]

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([approvalStatus])
}

model AngelTrackEnrollment {
  id           String         @id @default(cuid())
  profileId    String
  profile      AngelProfile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  track        AngelTrack
  status       AngelTrackStatus @default(INTERESTED)
  approvedAt   DateTime?
  approvedById String?
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([profileId, track])
  @@index([track, status])
}

model AngelTrackTrainingRequirement {
  id        String     @id @default(cuid())
  track     AngelTrack
  courseId  String
  required  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([track, courseId])
  @@index([track])
}

model AngelTrackTrainingExemption {
  id         String     @id @default(cuid())
  profileId  String
  profile    AngelProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  track      AngelTrack
  exemptedAt DateTime   @default(now())
  exemptedById String?
  reason     String?

  @@unique([profileId, track])
  @@index([track])
}

model AngelMission {
  id                String               @id @default(cuid())
  campaignId        String
  campaign          HumanitarianCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  track             AngelTrack
  type              AngelMissionType
  title             String
  description       String
  isRemote          Boolean              @default(false)
  location          String?
  startsAt          DateTime?
  endsAt            DateTime?
  capacity          Int                  @default(1)
  requiresVehicle   Boolean              @default(false)
  requiredLanguages String[]             @default([])
  estimatedMinutes  Int?
  status            AngelMissionStatus   @default(DRAFT)
  createdById       String
  signups           AngelMissionSignup[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([campaignId, track, status])
}

model AngelMissionSignup {
  id              String             @id @default(cuid())
  missionId       String
  mission         AngelMission       @relation(fields: [missionId], references: [id], onDelete: Cascade)
  profileId       String
  profile         AngelProfile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  status          AngelSignupStatus  @default(PENDING)
  note            String?
  minutesCredited Int?
  decidedById     String?
  reminderSentAt  DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([missionId, profileId])
  @@index([profileId, status])
}

model AngelHourLog {
  id         String       @id @default(cuid())
  profileId  String
  profile    AngelProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  track      AngelTrack
  minutes    Int
  source     String
  sourceId   String?
  occurredAt DateTime     @default(now())
  note       String?
  createdAt  DateTime     @default(now())

  @@index([profileId, occurredAt])
}

model AngelMilestone {
  id         String       @id @default(cuid())
  profileId  String
  profile    AngelProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  key        String
  achievedAt DateTime     @default(now())

  @@unique([profileId, key])
  @@index([profileId])
}

model AngelVolunteerCertificate {
  id            String       @id @default(cuid())
  profileId     String       @unique
  profile       AngelProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  verifyCode    String       @unique
  volunteerName String
  campaignName  String
  tracks        String[]
  totalMinutes  Int
  periodStart   DateTime?
  periodEnd     DateTime?
  issuedAt      DateTime     @default(now())
}

model AngelAnnouncement {
  id          String               @id @default(cuid())
  campaignId  String?
  campaign    HumanitarianCampaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  track       AngelTrack?
  title       String
  body        String
  createdById String
  publishedAt DateTime?
  createdAt   DateTime             @default(now())

  @@index([campaignId, track])
}

model AngelWellbeingCheckin {
  id        String       @id @default(cuid())
  profileId String
  profile   AngelProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  score     Int
  note      String?
  createdAt DateTime     @default(now())

  @@index([profileId, createdAt])
}

model AngelSupervisionNote {
  id        String       @id @default(cuid())
  profileId String
  profile   AngelProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  authorId  String
  note      String
  createdAt DateTime     @default(now())

  @@index([profileId, createdAt])
}

model HumanitarianAngel {
