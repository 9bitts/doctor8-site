// ─────────────────────────────────────────
// CORE USER
// ─────────────────────────────────────────

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  emailVerified   DateTime?
  phone           String?    // E.164 digits only (e.g. 5511999999999)
  phoneVerified   DateTime?
  passwordHash    String?    // null for OAuth users
  role            UserRole
  region          String     @default("US") @db.VarChar(2)
  language        String     @default("en")
  timezone        String     @default("America/Sao_Paulo")
  jitQueueEntries   JitQueue[]  @relation("JitQueuePatient")
  humanitarianQueueEntries HumanitarianQueueEntry[] @relation("HumanitarianQueuePatient")
  humanitarianVolunteers   HumanitarianVolunteer[]  @relation("HumanitarianVolunteer")
  humanitarianIntakes        HumanitarianIntake[]     @relation("HumanitarianIntakePatient")
  humanitarianVolunteerOnlineAlerts HumanitarianVolunteerOnlineAlert[] @relation("HumanitarianVolunteerOnlineAlert")
  partnerIntakes             PartnerIntake[]          @relation("PartnerIntakePatient")
  angelProfile               AngelProfile?
  humanitarianAngels         HumanitarianAngel[]      @relation("HumanitarianAngelUser")
  angelFollowUpsAuthored     HumanitarianAngelFollowUp[] @relation("AngelFollowUpAuthor")
  angelFollowUpsAsPatient    HumanitarianAngelFollowUp[] @relation("AngelFollowUpPatient")
  angelAssignmentsAuthored   HumanitarianAngelAssignment[] @relation("AngelAssignmentAngel")
  angelAssignmentsAsPatient  HumanitarianAngelAssignment[] @relation("AngelAssignmentPatient")

  // Soft delete — GDPR right to erasure
  // After 30 days we hard-delete PHI, keep anonymized stats
  deletedAt       DateTime?
  deletionScheduledAt DateTime?
  anonymizedAt    DateTime?

  // Session security — HIPAA
  lastLoginAt     DateTime?
  lastLoginIp     String?    // @encrypted — stored encrypted
  failedLoginAttempts Int    @default(0)
  lockedUntil     DateTime?
  tokenVersion    Int        @default(0)

  // MFA (phase 2)
  mfaEnabled      Boolean    @default(false)
  mfaSecret       String?    // @encrypted

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  patientProfile      PatientProfile?
  professionalProfile ProfessionalProfile?
  psychoanalystProfile PsychoanalystProfile?
  integrativeTherapistProfile IntegrativeTherapistProfile?
  accounts          Account[]
  sessions          Session[]
  consents          Consent[]
  auditLogs         AuditLog[]
  sentMessages      Message[]       @relation("SentMessages")
  receivedMessages  Message[]       @relation("ReceivedMessages")
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  subscription      Subscription?
  dataExportRequests DataExportRequest[]
  supportTickets     SupportTicket[]
  patientFavorites  PatientFavorite[]  @relation("PatientFavorites")
  professionalReviews ProfessionalReview[] @relation("PatientReviews")
  buyingClubMembers BuyingClubMember[]
  organizationMemberships OrganizationMember[]
  employerMemberships   EmployerMember[]
  pharmacyStoreMemberships PharmacyStoreMember[]
  laboratoryMemberships    LaboratoryMember[]
  occupationalPhysicianLinks EmployerOccupationalPhysician[]
  clubStampEntries      ClubStampEntry[]
  clubDiversityAwards   ClubDiversityAward[]
  providerLicenseDocuments ProviderLicenseDocument[]
  patientProfessionalLinksAsPatient      PatientProfessionalLink[] @relation("PatientProfessionalLinkPatient")
  patientProfessionalLinksAsProfessional PatientProfessionalLink[] @relation("PatientProfessionalLinkProfessional")
  emissionReportsAsPatient             ProfessionalEmissionReport[] @relation("EmissionReportPatient")
  emissionReportsAsProfessional        ProfessionalEmissionReport[] @relation("EmissionReportProfessional")
  paymentRefunds                       PaymentRefund[] @relation("PaymentRefundUser")
  orgLedgerEntriesCreated              OrganizationLedgerEntry[] @relation("OrgLedgerCreatedBy")
  patientRecordsLinked                 PatientRecord[] @relation("PatientRecordLinkedUser")
  patientProfilesReviewed              PatientProfile[] @relation("PatientProfileReviewedBy")

  // Course marketplace — admin grants partner instructors upload access
  courseCreatorApproved    Boolean   @default(false)
  courseCreatorApprovedAt  DateTime?
  courseCreatorApprovedBy  String?

  coursesInstructed        Course[]              @relation("CourseInstructor")
  courseEnrollments        CourseEnrollment[]
  coursePurchases          CoursePurchase[]
  courseConnectionRedemptions CourseConnectionRedemption[]

  @@index([email])
  @@index([role])
  @@index([region])
}

// Professional registration documents (CRM/CRP/etc.) for verification — all provider roles.
model ProviderLicenseDocument {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  label     String?
  fileKey   String
  fileName  String
  mimeType  String
  fileSize  Int

  createdAt DateTime @default(now())

  @@index([userId])
}

// NextAuth required models
model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────
// PATIENT PROFILE
// ─────────────────────────────────────────

model PatientProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Basic info — @encrypted in application layer (HIPAA PHI)
  firstName     String   // @encrypted
  lastName      String   // @encrypted
  dateOfBirth   String?   // @encrypted — ISO date string YYYY-MM-DD
  phone         String?  // @encrypted — PHI
  avatarUrl     String?

  // Address — @encrypted (PHI)
  addressLine1  String?  // @encrypted
  addressLine2  String?  // @encrypted
  city          String?
  state         String?
  country       String?  @default("US")
  zipCode       String?  // @encrypted

  // P1-e: extra registration fields (match PatientRecord)
  cpf           String?  // @encrypted — opcional (paciente no exterior pode não ter)
  sex           String?  // opcional — "M", "F", "O"

  // Emergency contact
  emergencyContactName  String? // @encrypted
  emergencyContactPhone String? // @encrypted

  // Medical history
  bloodType     String?
  allergies     String? // @encrypted — PHI
  chronicConditions String? // @encrypted — PHI
  notes         String? // @encrypted — PHI

  // Admin monitoring (not PHI)
  adminNote         String?
  adminReviewedAt   DateTime?
  adminReviewedById String?
  adminReviewedBy   User?    @relation("PatientProfileReviewedBy", fields: [adminReviewedById], references: [id], onDelete: SetNull)

  // First-touch acquisition (immutable after set at signup)
  acquisitionChannel    PatientAcquisitionChannel?
  acquisitionCampaign   String?
  acquisitionRecordedAt DateTime?
  acquisitionReferrer   String?

  /// Normalized plaintext index for professional platform search (name, email, phone).
  searchText            String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  medications       Medication[]
  appointments      Appointment[]
  medicalDocuments  MedicalDocument[]
  sharedRecords     SharedRecord[]

  @@index([userId])
  @@index([searchText])
}

// ─────────────────────────────────────────
// PARTNER INTAKES (ACURA Brasil / SOS Venezuela)
// ─────────────────────────────────────────

model PartnerIntake {
  id                       String              @id @default(cuid())
  partner                  String              @default("acura")
  campaign                 String              @default("sos_venezuela")
  protocolo                String              @unique

  email                    String
  emailNormalized          String
  patientUserId            String?
  patientUser              User?               @relation("PartnerIntakePatient", fields: [patientUserId], references: [id], onDelete: SetNull)

  requesterName            String
  phoneJson                Json

  patientNameEnc           String?
  ageEnc                   String?
  relationship             String
  location                 String
  careTypeEnc              String?
  priorityEnc              String?
  symptomsEnc              String?
  notesEnc                 String?

  acuraStatus              PartnerIntakeStatus @default(NOVA)
  triageNotes              String?
  assignedVolunteerLabel   String?
  referralSource           String?

  clickedDoctor8RegisterAt DateTime?
  clickedDoctor8LoginAt    DateTime?
  clickedWhatsappHelpAt    DateTime?
  doctor8RegisteredFlag    Boolean             @default(false)
  doctor8EmailCheckedAt    DateTime?
  doctor8EmailStatus       String?

  lgpdPrivacyAccepted      Boolean             @default(false)
  lgpdPrivacyVersion       String?
  lgpdPrivacyAt            DateTime?

  submittedAt              DateTime
  lastSyncedAt             DateTime            @updatedAt
  createdAt                DateTime            @default(now())

  events                   PartnerIntakeEvent[]

  @@index([emailNormalized])
  @@index([patientUserId])
  @@index([acuraStatus])
  @@index([submittedAt])
}

model PartnerIntakeEvent {
  id           String                   @id @default(cuid())
  intakeId     String
  intake       PartnerIntake            @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  type         PartnerIntakeEventType
  occurredAt   DateTime
  payload      Json?
  source       String                   @default("acura")
  externalId   String?
  createdAt    DateTime                 @default(now())

  @@unique([intakeId, externalId])
  @@index([intakeId, occurredAt])
}

// ─────────────────────────────────────────
// PROFESSIONAL PROFILE
// ─────────────────────────────────────────

model ProfessionalProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName       String
  lastName        String
  avatarUrl       String?
  phone           String?  // @encrypted

  // Professional credentials
  licenseNumber   String   // CRM, CRP, CRN, etc.
  licenseState    String?
  licenseCountry  String   @default("US")
  specialty       String
  subspecialties  String[] @default([])
  bio             String?

  // CV (PDF) — psychologists only
  cvFileKey       String?
  cvFileName      String?
  cvFileSize      Int?

  // Practice info
  clinicName      String?
  clinicAddress   String?
  clinicCity      String?
  clinicState     String?
  clinicCountry   String?
  clinicZip       String?
  clinicLatitude  Float?
  clinicLongitude Float?

  // DEPRECATED: no longer used. Digital signature now uses Lacuna Rest PKI Core
  // (cloud certificate chosen on the hosted signing page). Kept to avoid a
  // destructive migration; safe to drop in a future migration.
  digitalSignProvider String?
  digitalSignCpf      String?

  // Teleconsult
  acceptsTeleconsult  Boolean @default(true)
  acceptsInPerson     Boolean @default(false)
  consultPrice        Float   // in cents (USD or EUR cents)
  currency            String  @default("USD")

  // Availability (JSON: {dayOfWeek: [startTime, endTime]})
  availability    Json?
  timezone        String  @default("America/Sao_Paulo")

  // Verification
  verified        Boolean  @default(false)
  verifiedAt      DateTime?
  verifiedBy      String?

  // AcuraBrasil volunteer badge (opt-in; shown on booking cards + public profile)
  acuraVolunteer  Boolean  @default(false)

  // P8b scheduled volunteer — admin approval (gradual rollout via env flag)
  volunteerScheduledApproved    Boolean   @default(false)
  volunteerScheduledApprovedAt  DateTime?
  volunteerScheduledApprovedBy  String?

  // Payouts — Stripe Connect Express (85% after refund window + rateio bonus from 15% pool)
  stripeConnectAccountId String?

  // Integrative medicine (physician portal)
  practicesIntegrativeMedicine Boolean  @default(false)
  integrativeHubSeenAt           DateTime?

  consultationPayouts    ConsultationProfessionalPayout[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  appointments        Appointment[]
