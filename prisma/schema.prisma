  availabilitySlots   AvailabilitySlot[]
  virtualCard         VirtualCard?        @relation("ProfessionalVirtualCard")
  patientRecords      PatientRecord[]
  sharedDocuments  SharedRecord[]  @relation("DocsSharedWithProfessional")
  resources             Resource[]
  resourceCollections   ResourceCollection[]

  jitSessions       JitSession[]
  favorites         PatientFavorite[]
  reviews           ProfessionalReview[]

  healthPlans       ProfessionalHealthPlan[]
  practiceLocations PracticeLocation[]      @relation("ProfessionalLocations")
  services          ProviderService[]       @relation("ProfessionalServices")
  slotAlerts        SlotAvailabilityAlert[] @relation("ProfessionalSlotAlerts")

  documentTemplates     DocumentTemplate[]
  prescriptionTemplates PrescriptionTemplate[]

  clinicMemberships     ClinicMember[]
  organizationLinks     OrganizationProfessional[]
  employerLinks         EmployerLinkedPsychologist[]
  organizationRepasseRules OrganizationRepasseRule[]
  chartSharesCreated    PatientRecordShare[] @relation("ChartSharesCreated")
  chartSharesReceived   PatientRecordShare[] @relation("ChartSharesReceived")
  chartInvitesSent      PatientChartInvite[]
  psychologyAnamnesisInvites PsychologyAnamnesisInvite[]
  googleCalendar        ProfessionalGoogleCalendar?
  vaccinationsRecorded  PatientVaccination[]
  odontogramsRecorded   PatientOdontogram[]
  audiogramsRecorded    PatientAudiogram[]
  nutritionAnthropometry NutritionAnthropometryEntry[]
  nutritionMealPlans     NutritionMealPlan[]
  nutritionIntakeForms   NutritionIntakeForm[]
  nutritionFoodAnamnesis NutritionFoodAnamnesis[]
  nursingAssessments     NursingAssessment[]
  nursingCarePlans       NursingCarePlan[]
  nursingScaleEntries    NursingScaleEntry[]
  nursingIntakeForms     NursingIntakeForm[]
  nursingSbarReports     NursingSbarReport[]
