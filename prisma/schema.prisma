  rating         Int                 // 1–5
  comment        String?             @db.Text
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([patientUserId, professionalId])
  @@index([professionalId])
}

model PsychoanalystReview {
  id              String              @id @default(cuid())
  patientUserId   String
  psychoanalystId String
  psychoanalyst   PsychoanalystProfile @relation(fields: [psychoanalystId], references: [id], onDelete: Cascade)
  rating          Int
  comment         String?             @db.Text
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([patientUserId, psychoanalystId])
  @@index([psychoanalystId])
}

// ─────────────────────────────────────────
// COMPLIANCE — HIPAA + GDPR
// ─────────────────────────────────────────

// Every access to PHI must create an audit log — HIPAA requirement
model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  user        User?       @relation(fields: [userId], references: [id])

  action      AuditAction
  resource    String      // e.g. "PatientProfile", "MedicalDocument"
  resourceId  String?
  ipAddress   String?     // @encrypted
  userAgent   String?
  details     Json?       // additional context, never store PHI here

  createdAt   DateTime    @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// Explicit consent tracking — GDPR requirement
model Consent {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        ConsentType
  version     String      // "1.0", "1.1" etc — matches document version
  granted     Boolean
  grantedAt   DateTime    @default(now())
  revokedAt   DateTime?
  ipAddress   String?     // @encrypted
  userAgent   String?

  @@unique([userId, type, version])
  @@index([userId])
}

// GDPR right to data portability + right to erasure
model DataExportRequest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  type        String   // "export" or "deletion"
  status      String   @default("pending") // pending, processing, completed, failed
  fileUrl     String?  // S3 URL of export ZIP (for export requests)
  completedAt DateTime?
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model SupportTicket {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])

  subject     String
  body        String   @db.Text
  status      String   @default("open") // open, in_progress, resolved
  priority    String   @default("normal")
  source      String   @default("ai_escalation")
  contactEmail String?

  slaDueAt    DateTime?
  resolvedAt  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ────────────────────────────────────────────
// PATIENT RECORD (chart created by a professional)
// A patient "file" the doctor keeps. May or may not be linked
// to a real user account (linkedUserId). Nothing is shared with
// the patient until the doctor explicitly shares it.
// ────────────────────────────────────────────
model PatientRecord {
  id              String   @id @default(cuid())
  professionalId  String
  professional    ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  // Patient data filled by the professional — @encrypted in app layer (PHI)
  firstName       String   // @encrypted
  lastName        String   // @encrypted
  email           String?  // used to link/invite the patient
  phone           String?  // @encrypted
  dateOfBirth     String?   // @encrypted — ISO date string YYYY-MM-DD
  notes           String?  @db.Text // @encrypted — general chart notes
  cpf             String?  // @encrypted — opcional (paciente no exterior pode não ter)
  sex             String?  // opcional — "M", "F", "O" ou livre
  addressLine1    String?  // @encrypted — rua, número, complemento
  city            String?
  state           String?  // estado/província/região
  country         String?  @default("BR")
  zipCode         String?  // @encrypted — CEP / ZIP / código postal

  // Link to a real account, once the patient has one
  linkedUserId    String?
  linkedUser      User? @relation("PatientRecordLinkedUser", fields: [linkedUserId], references: [id], onDelete: SetNull)
  // Normalized plaintext for search (first + last + email, accent-stripped)
  searchText      String?
  // Clinical records attached to this chart
  medicalDocuments MedicalDocument[]
  resourceShares   ResourceShare[]
  tags             PatientRecordTag[]
  diagnoses        PatientDiagnosis[]
  metricSnapshots  ClinicalMetricSnapshot[]
  vaccinations     PatientVaccination[]
  odontogram         PatientOdontogram?
  audiograms         PatientAudiogram[]
  colleagueShares  PatientRecordShare[]
  chartInvites     PatientChartInvite[]
  psychologyAnamnesisInvites PsychologyAnamnesisInvite[]
  nutritionAnthropometry NutritionAnthropometryEntry[]
  nutritionMealPlans     NutritionMealPlan[]
  nutritionIntakeForms   NutritionIntakeForm[]
  nutritionFoodAnamnesis NutritionFoodAnamnesis[]
  nutritionFoodDiary     NutritionFoodDiaryEntry[]
  nursingAssessments     NursingAssessment[]
  nursingCarePlans       NursingCarePlan[]
  nursingScaleEntries    NursingScaleEntry[]
  nursingIntakeForms     NursingIntakeForm[]
  nursingMonitoring      NursingMonitoringEntry[]
  nursingSbarReports     NursingSbarReport[]
  nursingMedChecks       NursingMedCheck[]
  nursingMedicationRx    NursingMedicationPrescription[]
  pharmacyIntakeForms    PharmacyIntakeForm[]
  pharmacyMedReviews     PharmacyMedReview[]
  pharmacyReconciliations PharmacyReconciliation[]
  pharmacyMonitoring     PharmacyMonitoringEntry[]
  pharmacyPrescriptions  PharmacyPrescription[]
  pharmacyEducationSessions PharmacyEducationSession[]
  pharmacyDispensingRecords PharmacyDispensingRecord[]
  pharmacyInteractionChecks PharmacyInteractionCheck[]
  dentalAnamnesis          DentalAnamnesis[]
  dentalTreatmentPlans     DentalTreatmentPlan[]
  dentalProstheticOrders   DentalProstheticOrder[]
  orthodonticRecords       OrthodonticRecord[]
  dentalClinicalPhotos     DentalClinicalPhoto[]
  periodontograms          PatientPeriodontogram[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([professionalId])
  @@index([email])
  @@index([linkedUserId])
  @@index([searchText])

}

model PatientChartInvite {
  id                   String                   @id @default(cuid())
  patientRecordId      String
  patientRecord        PatientRecord            @relation(fields: [patientRecordId], references: [id], onDelete: Cascade)
  sentByProfessionalId String
  sentBy               ProfessionalProfile      @relation(fields: [sentByProfessionalId], references: [id], onDelete: Cascade)
  email                String
  status               PatientChartInviteStatus @default(SENT)
  sentAt               DateTime                 @default(now())
  linkedAt             DateTime?

  @@index([patientRecordId])
  @@index([email])
  @@index([sentByProfessionalId])
}

model PsychologyAnamnesisInvite {
  id              String                    @id @default(cuid())
  token           String                    @unique @default(cuid())
  patientRecordId String
  patientRecord   PatientRecord             @relation(fields: [patientRecordId], references: [id], onDelete: Cascade)
  professionalId  String
  professional    ProfessionalProfile       @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  status          PsychologyAnamnesisStatus @default(PENDING)
  viewCount       Int                       @default(0)
  maxViews        Int                       @default(30)
  responses       String?                   @db.Text // @encrypted JSON
  expiresAt       DateTime
  completedAt     DateTime?
  createdAt       DateTime                  @default(now())

  @@index([token])
  @@index([patientRecordId])
  @@index([professionalId])
  @@index([status])
}

model ProfessionalGoogleCalendar {
  id               String              @id @default(cuid())
  professionalId   String              @unique
  professional     ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  refreshToken     String              // @encrypted
  accessToken      String?             // @encrypted
  tokenExpiresAt   DateTime?
  calendarId       String              @default("primary")
  syncEnabled      Boolean             @default(true)
  externalBusyBlocks Json?             // [{ start, end }] from Google pull
  lastSyncedAt     DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([professionalId])
}

// ────────────────────────────────────────────
// ORGANIZATION — CNPJ clinic / consultório management (Phase 1)
// ────────────────────────────────────────────

model Organization {
  id                   String   @id @default(cuid())
  cnpj                 String   @unique
  razaoSocial          String
  nomeFantasia         String
  inscricaoMunicipal   String?
  contactEmail         String?
  contactPhone         String?
  logoUrl              String?
  slug                 String   @unique
  inviteCode           String   @unique @default(cuid())

  responsibleFirstName String
  responsibleLastName  String

  addressStreet        String?
  addressNumber        String?
  addressComplement    String?
  addressNeighborhood  String?
  addressCity          String?
  addressState         String?
  addressZip           String?
  addressCountry       String   @default("BR")

  timezone             String   @default("America/Sao_Paulo")
  currency             String   @default("BRL")
  whatsappRemindersEnabled Boolean @default(true)

  members              OrganizationMember[]
  professionals        OrganizationProfessional[]
  linkedProviders      OrganizationLinkedProvider[]
  repasseRules         OrganizationRepasseRule[]
  invites              OrganizationInvite[]
  ledgerEntries        OrganizationLedgerEntry[]
  healthPlans          OrganizationHealthPlan[]
  tissGuides           TissGuide[]
  tissBatches          TissBatch[]
  employees            OrganizationEmployee[]
  payrollEntries       OrganizationPayrollEntry[]
  invoices             OrganizationInvoice[]
  suppliers            OrganizationSupplier[]
  purchaseOrders       OrganizationPurchaseOrder[]
  surveyResponses      OrganizationSurveyResponse[]

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([slug])
  @@index([cnpj])
}

model OrganizationMember {
  id             String                   @id @default(cuid())
  organizationId String
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           OrganizationMemberRole
  status         OrganizationMemberStatus @default(ACTIVE)

  invitedAt      DateTime?
  joinedAt       DateTime                 @default(now())

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
}

model OrganizationProfessional {
  id             String                         @id @default(cuid())
  organizationId String
  organization   Organization                   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  professionalId String
  professional   ProfessionalProfile            @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  repassePercent Float                          @default(70)
  status         OrganizationProfessionalStatus @default(ACTIVE)

  joinedAt       DateTime                       @default(now())

  @@unique([organizationId, professionalId])
  @@index([professionalId])
  @@index([organizationId])
}

model OrganizationLinkedProvider {
  id                String                         @id @default(cuid())
  organizationId    String
  organization      Organization                   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  providerType      ProviderType
  providerProfileId String
  repassePercent    Float                          @default(70)
  status            OrganizationProfessionalStatus @default(ACTIVE)
  joinedAt          DateTime                       @default(now())

  @@unique([organizationId, providerType, providerProfileId])
  @@index([organizationId])
  @@index([providerType, providerProfileId])
}

model OrganizationRepasseRule {
  id             String              @id @default(cuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  professionalId String?
  professional   ProfessionalProfile?  @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  percent        Float
  label          String?

  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([organizationId])
  @@index([professionalId])
}

model OrganizationInvite {
  id             String                 @id @default(cuid())
  organizationId String
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           OrganizationMemberRole
  token          String                 @unique
  expiresAt      DateTime
  acceptedAt     DateTime?

  createdAt      DateTime               @default(now())

  @@index([organizationId])
  @@index([email])
}

model OrganizationLedgerEntry {
  id             String                   @id @default(cuid())
  organizationId String
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  type           OrganizationLedgerType
  status         OrganizationLedgerStatus @default(PENDING)
  description    String
  category       String?
  amountCents    Int
  currency       String                   @default("BRL")
  dueDate        DateTime?
  paidAt         DateTime?
  professionalId String?
  professional   ProfessionalProfile? @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  appointmentId  String?
  appointment    Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  createdById    String?
  createdBy      User? @relation("OrgLedgerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, dueDate])
}

// ────────────────────────────────────────────
// ORGANIZATION Phase 3 — TISS, RH, contabilidade, compras, NPS
// ────────────────────────────────────────────

model OrganizationHealthPlan {
