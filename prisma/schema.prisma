// ─────────────────────────────────────────
// CORE USER
// ─────────────────────────────────────────

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  emailVerified   DateTime?
  phone           String?    // E.164 digits only (e.g. 5511999999999)
  phoneVerified   DateTime?
  passwordHash    String?    // null for OAuth users
  role            UserRole
  region          String     @default("US") @db.VarChar(2)
  language        String     @default("en")
  timezone        String     @default("America/Sao_Paulo")
  jitQueueEntries   JitQueue[]  @relation("JitQueuePatient")
  humanitarianQueueEntries HumanitarianQueueEntry[] @relation("HumanitarianQueuePatient")
  humanitarianVolunteers   HumanitarianVolunteer[]  @relation("HumanitarianVolunteer")
  humanitarianIntakes        HumanitarianIntake[]     @relation("HumanitarianIntakePatient")
  angelProfile               AngelProfile?
  humanitarianAngels         HumanitarianAngel[]      @relation("HumanitarianAngelUser")
  angelFollowUpsAuthored     HumanitarianAngelFollowUp[] @relation("AngelFollowUpAuthor")
  angelFollowUpsAsPatient    HumanitarianAngelFollowUp[] @relation("AngelFollowUpPatient")
  angelAssignmentsAuthored   HumanitarianAngelAssignment[] @relation("AngelAssignmentAngel")
  angelAssignmentsAsPatient  HumanitarianAngelAssignment[] @relation("AngelAssignmentPatient")

  // Soft delete — GDPR right to erasure
  // After 30 days we hard-delete PHI, keep anonymized stats
  deletedAt       DateTime?
  deletionScheduledAt DateTime?
  anonymizedAt    DateTime?

  // Session security — HIPAA
  lastLoginAt     DateTime?
  lastLoginIp     String?    // @encrypted — stored encrypted
  failedLoginAttempts Int    @default(0)
  lockedUntil     DateTime?
  tokenVersion    Int        @default(0)

  // MFA (phase 2)
  mfaEnabled      Boolean    @default(false)
  mfaSecret       String?    // @encrypted

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  patientProfile      PatientProfile?
  professionalProfile ProfessionalProfile?
  psychoanalystProfile PsychoanalystProfile?
  integrativeTherapistProfile IntegrativeTherapistProfile?
  accounts          Account[]
  sessions          Session[]
  consents          Consent[]
  auditLogs         AuditLog[]
  sentMessages      Message[]       @relation("SentMessages")
  receivedMessages  Message[]       @relation("ReceivedMessages")
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  subscription      Subscription?
  dataExportRequests DataExportRequest[]
  patientFavorites  PatientFavorite[]  @relation("PatientFavorites")
  professionalReviews ProfessionalReview[] @relation("PatientReviews")
  buyingClubMembers BuyingClubMember[]
  organizationMemberships OrganizationMember[]
  clubStampEntries      ClubStampEntry[]
  clubDiversityAwards   ClubDiversityAward[]
  providerLicenseDocuments ProviderLicenseDocument[]
  patientProfessionalLinksAsPatient      PatientProfessionalLink[] @relation("PatientProfessionalLinkPatient")
  patientProfessionalLinksAsProfessional PatientProfessionalLink[] @relation("PatientProfessionalLinkProfessional")
  emissionReportsAsPatient             ProfessionalEmissionReport[] @relation("EmissionReportPatient")
  emissionReportsAsProfessional        ProfessionalEmissionReport[] @relation("EmissionReportProfessional")

  @@index([email])
  @@index([role])
  @@index([region])
}

// Professional registration documents (CRM/CRP/etc.) for verification — all provider roles.
model ProviderLicenseDocument {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  label     String?
  fileKey   String
  fileName  String
  mimeType  String
  fileSize  Int

  createdAt DateTime @default(now())

  @@index([userId])
}

// NextAuth required models
model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────
// PATIENT PROFILE
// ─────────────────────────────────────────

model PatientProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Basic info — @encrypted in application layer (HIPAA PHI)
  firstName     String   // @encrypted
  lastName      String   // @encrypted
  dateOfBirth   String?   // @encrypted — ISO date string YYYY-MM-DD
  phone         String?  // @encrypted — PHI
  avatarUrl     String?

  // Address — @encrypted (PHI)
  addressLine1  String?  // @encrypted
  addressLine2  String?  // @encrypted
  city          String?
  state         String?
  country       String?  @default("US")
  zipCode       String?  // @encrypted

  // P1-e: extra registration fields (match PatientRecord)
  cpf           String?  // @encrypted — opcional (paciente no exterior pode não ter)
  sex           String?  // opcional — "M", "F", "O"

  // Emergency contact
  emergencyContactName  String? // @encrypted
  emergencyContactPhone String? // @encrypted

  // Medical history
  bloodType     String?
  allergies     String? // @encrypted — PHI
  chronicConditions String? // @encrypted — PHI
  notes         String? // @encrypted — PHI

  // Admin monitoring (not PHI)
  adminNote         String?
  adminReviewedAt   DateTime?
  adminReviewedById String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  medications       Medication[]
  appointments      Appointment[]
  medicalDocuments  MedicalDocument[]
  sharedRecords     SharedRecord[]

  @@index([userId])
}

// ─────────────────────────────────────────
// PROFESSIONAL PROFILE
// ─────────────────────────────────────────

model ProfessionalProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName       String
  lastName        String
  avatarUrl       String?
  phone           String?  // @encrypted

  // Professional credentials
  licenseNumber   String   // CRM, CRP, CRN, etc.
  licenseState    String?
  licenseCountry  String   @default("US")
  specialty       String
  subspecialties  String[] @default([])
  bio             String?

  // CV (PDF) — psychologists only
  cvFileKey       String?
  cvFileName      String?
  cvFileSize      Int?

  // Practice info
  clinicName      String?
  clinicAddress   String?
  clinicCity      String?
  clinicState     String?
  clinicCountry   String?
  clinicZip       String?
  clinicLatitude  Float?
  clinicLongitude Float?

  // DEPRECATED: no longer used. Digital signature now uses Lacuna Rest PKI Core
  // (cloud certificate chosen on the hosted signing page). Kept to avoid a
  // destructive migration; safe to drop in a future migration.
  digitalSignProvider String?
  digitalSignCpf      String?

  // Teleconsult
  acceptsTeleconsult  Boolean @default(true)
  acceptsInPerson     Boolean @default(false)
  consultPrice        Float   // in cents (USD or EUR cents)
  currency            String  @default("USD")

  // Availability (JSON: {dayOfWeek: [startTime, endTime]})
  availability    Json?
  timezone        String  @default("America/Sao_Paulo")

  // Verification
  verified        Boolean  @default(false)
  verifiedAt      DateTime?
  verifiedBy      String?

  // AcuraBrasil volunteer badge (opt-in; shown on booking cards + public profile)
  acuraVolunteer  Boolean  @default(false)

  // P8b scheduled volunteer — admin approval (gradual rollout via env flag)
  volunteerScheduledApproved    Boolean   @default(false)
  volunteerScheduledApprovedAt  DateTime?
  volunteerScheduledApprovedBy  String?

  // Payouts (rateio) — conta Stripe Connect para receber o rateio mensal
  stripeConnectAccountId String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  appointments        Appointment[]
  medicalDocuments    MedicalDocument[]
  prescriptions       Prescription[]
  availabilitySlots   AvailabilitySlot[]
  virtualCard         VirtualCard?        @relation("ProfessionalVirtualCard")
  patientRecords      PatientRecord[]
  sharedDocuments  SharedRecord[]  @relation("DocsSharedWithProfessional")
  resources      Resource[]

  jitSessions       JitSession[]
  favorites         PatientFavorite[]
  reviews           ProfessionalReview[]

  healthPlans       ProfessionalHealthPlan[]
  practiceLocations PracticeLocation[]      @relation("ProfessionalLocations")
  services          ProviderService[]       @relation("ProfessionalServices")
  slotAlerts        SlotAvailabilityAlert[] @relation("ProfessionalSlotAlerts")

  documentTemplates     DocumentTemplate[]
  prescriptionTemplates PrescriptionTemplate[]

  clinicMemberships     ClinicMember[]
  organizationLinks     OrganizationProfessional[]
  organizationRepasseRules OrganizationRepasseRule[]
  chartSharesCreated    PatientRecordShare[] @relation("ChartSharesCreated")
  chartSharesReceived   PatientRecordShare[] @relation("ChartSharesReceived")
  chartInvitesSent      PatientChartInvite[]
  psychologyAnamnesisInvites PsychologyAnamnesisInvite[]
  googleCalendar        ProfessionalGoogleCalendar?
  vaccinationsRecorded  PatientVaccination[]
  odontogramsRecorded   PatientOdontogram[]
  audiogramsRecorded    PatientAudiogram[]
  nutritionAnthropometry NutritionAnthropometryEntry[]
  nutritionMealPlans     NutritionMealPlan[]
  nutritionIntakeForms   NutritionIntakeForm[]
  nutritionFoodAnamnesis NutritionFoodAnamnesis[]
  nursingAssessments     NursingAssessment[]
  nursingCarePlans       NursingCarePlan[]
  nursingScaleEntries    NursingScaleEntry[]
  nursingIntakeForms     NursingIntakeForm[]
  nursingSbarReports     NursingSbarReport[]
  nursingMedChecks       NursingMedCheck[]       @relation("NurseMedChecks")
  nursingMedicationRx    NursingMedicationPrescription[]
  pharmacyIntakeForms    PharmacyIntakeForm[]
  pharmacyMedReviews     PharmacyMedReview[]
  pharmacyReconciliations PharmacyReconciliation[]
  pharmacyPrescriptions  PharmacyPrescription[]
  pharmacyEducationSessions PharmacyEducationSession[]
  pharmacyDispensingRecords PharmacyDispensingRecord[]
  pharmacyInteractionChecks PharmacyInteractionCheck[]
  dentalAnamnesis          DentalAnamnesis[]
  dentalTreatmentPlans     DentalTreatmentPlan[]
  dentalProstheticOrders   DentalProstheticOrder[]
  orthodonticRecords       OrthodonticRecord[]
  dentalClinicalPhotos     DentalClinicalPhoto[]
  dentalChairs             DentalChair[]
  periodontogramsRecorded  PatientPeriodontogram[]

  // Rateio (livro aberto / profit-sharing)
  poolContributions       PoolContribution[]
  consultationValidations ConsultationValidation[]
  humanitarianVolunteers  HumanitarianVolunteer[]

  @@index([userId])
  @@index([specialty])
}

// ─────────────────────────────────────────
// PSYCHOANALYST PROFILE (non-regulated profession)
// ─────────────────────────────────────────

model PsychoanalystProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName       String
  lastName        String
  avatarUrl       String?
  phone           String?  // @encrypted

  // Formation triad (declaratory — no council registry)
  trainingInstitution   String
  personalAnalysisDone  Boolean  @default(false)
  theoreticalStudyDone  Boolean  @default(false)
  clinicalSupervision   Boolean  @default(false)
  yearsOfPractice       Int      @default(0)
  theoreticalLineage    String?
  associations          String[] @default([])
  publications          String?
  otherRegulatedProfession String?

  bio             String?

  // Practice info
  clinicName      String?
  clinicAddress   String?
  clinicCity      String?
  clinicState     String?
  clinicCountry   String?
  clinicZip       String?
  clinicLatitude  Float?
  clinicLongitude Float?

  acceptsTeleconsult  Boolean @default(true)
  acceptsInPerson     Boolean @default(false)
  consultPrice        Float
  currency            String  @default("USD")
  sessionDurationMins Int     @default(50)

  availability    Json?

  verified        Boolean  @default(false)
  verifiedAt      DateTime?
  verifiedBy      String?

  acuraVolunteer  Boolean  @default(false)

  // P8b scheduled volunteer — admin approval (gradual rollout via env flag)
  volunteerScheduledApproved    Boolean   @default(false)
  volunteerScheduledApprovedAt  DateTime?
  volunteerScheduledApprovedBy  String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointments        Appointment[]
  medicalDocuments    MedicalDocument[]
  analysandRecords    AnalysandRecord[]
  availabilitySlots   PsychoanalystAvailabilitySlot[]
  virtualCard         VirtualCard?        @relation("PsychoanalystVirtualCard")
  favorites           PsychoanalystFavorite[]
  reviews             PsychoanalystReview[]

  healthPlans         PsychoanalystHealthPlan[]
  practiceLocations   PracticeLocation[]        @relation("PsychoanalystLocations")
  services            ProviderService[]         @relation("PsychoanalystServices")
  slotAlerts          SlotAvailabilityAlert[]   @relation("PsychoanalystSlotAlerts")
  resources           Resource[]
  humanitarianVolunteers HumanitarianVolunteer[]
  poolContributions       PoolContribution[]
  consultationValidations ConsultationValidation[]

  @@index([userId])
}

model PsychoanalystAvailabilitySlot {
  id               String              @id @default(cuid())
  psychoanalystId  String
  psychoanalyst    PsychoanalystProfile  @relation(fields: [psychoanalystId], references: [id], onDelete: Cascade)

  dayOfWeek        Int
  startTime        String
  endTime          String
  slotDurationMins Int    @default(50)
  slotGapMins      Int    @default(0)
  volunteerOnly    Boolean @default(false)
  isActive         Boolean @default(true)

  @@index([psychoanalystId])
}

