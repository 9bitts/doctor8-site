// Doctor8 — Database Schema
// PostgreSQL via Prisma
// HIPAA & GDPR compliant design
//
// Key compliance decisions:
// - PHI fields are marked with @encrypted (handled in application layer)
// - All access to patient records creates an AuditLog entry
// - Users can request deletion (soft delete + scheduled hard delete)
// - Consent is tracked with timestamps and versions

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

