// Doctor8 — Database Schema
// PostgreSQL via Prisma
// HIPAA & GDPR compliant design
//
// Key compliance decisions:
// - PHI fields are marked with @encrypted (handled in application layer)
// - All access to patient records creates an AuditLog entry
// - Users can request deletion (soft delete + scheduled hard delete)
// - Consent is tracked with timestamps and versions

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum UserRole {
  PATIENT
  PROFESSIONAL
  PSYCHOANALYST
  ADMIN
}

enum ProviderType {
  HEALTH
  PSYCHOANALYST
}

enum UserRegion {
  US
  EU
  BR
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum AppointmentType {
  TELECONSULT
  IN_PERSON
}

enum DocumentType {
  PRESCRIPTION
  EXAM_REQUEST
  EXAM_RESULT
  CERTIFICATE
  REFERRAL
  CLINICAL_NOTE
  OTHER
}

enum PatientRecordTagKind {
  ALLERGY
  MEDICATION
  PREGNANT
  OTHER
}

enum DiagnosisStatus {
  ACTIVE
  RESOLVED
}

enum ClinicalRecordKind {
  ANAMNESIS
  EVOLUTION
  REPORT
  OTHER
}

enum MedicationFlow {
  CLINICAL    // Goes to patient medical history — shared with doctor
  PURCHASE    // Goes to collective purchase list — NOT clinical
}

enum ConsentType {
  TERMS_OF_SERVICE
  PRIVACY_POLICY
  HIPAA_AUTHORIZATION   // US only
  GDPR_CONSENT          // EU only
  MARKETING
}

enum AuditAction {
  LOGIN
  LOGOUT
  VIEW_RECORD
  CREATE_RECORD
  UPDATE_RECORD
  DELETE_RECORD
  EXPORT_DATA
  SHARE_RECORD
  PAYMENT
  PASSWORD_CHANGE
  EMAIL_CHANGE
  DATA_DELETION_REQUEST
}

enum JitMode {
  QUEUE      // paciente entra na fila, sistema distribui automaticamente
  SHOWCASE   // paciente escolhe o profissional disponível
}

enum JitSessionStatus {
  ONLINE
  PAUSED
  OFFLINE
}

enum JitQueueStatus {
  WAITING      // na fila, aguardando
  CALLED       // foi chamado, tem 2 min para entrar
  IN_PROGRESS  // em consulta
  DONE         // consulta concluída
  CANCELLED    // não respondeu no prazo ou desistiu
  NO_SHOW      // foi chamado e não entrou (2 min esgotados)
}
// ─────────────────────────────────────────
// CORE USER
// ─────────────────────────────────────────

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  emailVerified   DateTime?
  passwordHash    String?    // null for OAuth users
  role            UserRole
  region          UserRegion @default(US)
  language        String     @default("en")
  jitQueueEntries   JitQueue[]  @relation("JitQueuePatient")

  // Soft delete — GDPR right to erasure
  // After 30 days we hard-delete PHI, keep anonymized stats
  deletedAt       DateTime?
  deletionScheduledAt DateTime?

  // Session security — HIPAA
  lastLoginAt     DateTime?
  lastLoginIp     String?    // @encrypted — stored encrypted
  failedLoginAttempts Int    @default(0)
  lockedUntil     DateTime?

  // MFA (phase 2)
  mfaEnabled      Boolean    @default(false)
  mfaSecret       String?    // @encrypted

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  patientProfile      PatientProfile?
  professionalProfile ProfessionalProfile?
  psychoanalystProfile PsychoanalystProfile?
  accounts          Account[]
  sessions          Session[]
  consents          Consent[]
  auditLogs         AuditLog[]
  sentMessages      Message[]       @relation("SentMessages")
  receivedMessages  Message[]       @relation("ReceivedMessages")
  notifications     Notification[]
  subscription      Subscription?
  dataExportRequests DataExportRequest[]
  patientFavorites  PatientFavorite[]  @relation("PatientFavorites")
  professionalReviews ProfessionalReview[] @relation("PatientReviews")
  buyingClubMembers BuyingClubMember[]

  @@index([email])
  @@index([role])
  @@index([region])
}

// NextAuth required models
model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────
// PATIENT PROFILE
// ─────────────────────────────────────────

model PatientProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Basic info — @encrypted in application layer (HIPAA PHI)
  firstName     String   // @encrypted
  lastName      String   // @encrypted
  dateOfBirth   String?   // @encrypted — ISO date string YYYY-MM-DD
  phone         String?  // @encrypted — PHI
  avatarUrl     String?

  // Address — @encrypted (PHI)
  addressLine1  String?  // @encrypted
  addressLine2  String?  // @encrypted
  city          String?
  state         String?
  country       String?  @default("US")
  zipCode       String?  // @encrypted

  // P1-e: extra registration fields (match PatientRecord)
  cpf           String?  // @encrypted — opcional (paciente no exterior pode não ter)
  sex           String?  // opcional — "M", "F", "O"

  // Emergency contact
  emergencyContactName  String? // @encrypted
  emergencyContactPhone String? // @encrypted

  // Medical history
  bloodType     String?
  allergies     String? // @encrypted — PHI
  chronicConditions String? // @encrypted — PHI
  notes         String? // @encrypted — PHI

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  medications       Medication[]
  appointments      Appointment[]
  medicalDocuments  MedicalDocument[]
  sharedRecords     SharedRecord[]

  @@index([userId])
}

// ─────────────────────────────────────────
// PROFESSIONAL PROFILE
// ─────────────────────────────────────────

model ProfessionalProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName       String
  lastName        String
  avatarUrl       String?
  phone           String?  // @encrypted

  // Professional credentials
  licenseNumber   String   // CRM, CRP, CRN, etc.
  licenseState    String?
  licenseCountry  String   @default("US")
  specialty       String
  subspecialties  String[] @default([])
  bio             String?

  // Practice info
  clinicName      String?
  clinicAddress   String?
  clinicCity      String?
  clinicState     String?
  clinicCountry   String?
  clinicZip       String?
  clinicLatitude  Float?
  clinicLongitude Float?

  // DEPRECATED: no longer used. Digital signature now uses Lacuna Rest PKI Core
  // (cloud certificate chosen on the hosted signing page). Kept to avoid a
  // destructive migration; safe to drop in a future migration.
  digitalSignProvider String?
  digitalSignCpf      String?

  // Teleconsult
  acceptsTeleconsult  Boolean @default(true)
  acceptsInPerson     Boolean @default(false)
  consultPrice        Float   // in cents (USD or EUR cents)
  currency            String  @default("USD")

  // Availability (JSON: {dayOfWeek: [startTime, endTime]})
  availability    Json?

  // Verification
  verified        Boolean  @default(false)
  verifiedAt      DateTime?
  verifiedBy      String?

  // Payouts (rateio) — conta Stripe Connect para receber o rateio mensal
  stripeConnectAccountId String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  appointments        Appointment[]
  medicalDocuments    MedicalDocument[]
  prescriptions       Prescription[]
  availabilitySlots   AvailabilitySlot[]
  virtualCard         VirtualCard?        @relation("ProfessionalVirtualCard")
  patientRecords      PatientRecord[]
  sharedDocuments  SharedRecord[]  @relation("DocsSharedWithProfessional")
  resources      Resource[]

  jitSessions       JitSession[]
  favorites         PatientFavorite[]
  reviews           ProfessionalReview[]

  healthPlans       ProfessionalHealthPlan[]
  practiceLocations PracticeLocation[]      @relation("ProfessionalLocations")
  services          ProviderService[]       @relation("ProfessionalServices")
  slotAlerts        SlotAvailabilityAlert[] @relation("ProfessionalSlotAlerts")

  documentTemplates     DocumentTemplate[]
  prescriptionTemplates PrescriptionTemplate[]

  // Rateio (livro aberto / profit-sharing)
  poolContributions       PoolContribution[]
  consultationValidations ConsultationValidation[]

  @@index([userId])
  @@index([specialty])
}

// ─────────────────────────────────────────
// PSYCHOANALYST PROFILE (non-regulated profession)
// ─────────────────────────────────────────

model PsychoanalystProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName       String
  lastName        String
  avatarUrl       String?
  phone           String?  // @encrypted

  // Formation triad (declaratory — no council registry)
  trainingInstitution   String
  personalAnalysisDone  Boolean  @default(false)
  theoreticalStudyDone  Boolean  @default(false)
  clinicalSupervision   Boolean  @default(false)
  yearsOfPractice       Int      @default(0)
  theoreticalLineage    String?
  associations          String[] @default([])
  publications          String?
  otherRegulatedProfession String?

  bio             String?

  // Practice info
  clinicName      String?
  clinicAddress   String?
  clinicCity      String?
  clinicState     String?
  clinicCountry   String?
  clinicZip       String?
  clinicLatitude  Float?
  clinicLongitude Float?

  acceptsTeleconsult  Boolean @default(true)
  acceptsInPerson     Boolean @default(false)
  consultPrice        Float
  currency            String  @default("USD")
  sessionDurationMins Int     @default(50)

  availability    Json?

  verified        Boolean  @default(false)
  verifiedAt      DateTime?
  verifiedBy      String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointments        Appointment[]
  medicalDocuments    MedicalDocument[]
  analysandRecords    AnalysandRecord[]
  availabilitySlots   PsychoanalystAvailabilitySlot[]
  virtualCard         VirtualCard?        @relation("PsychoanalystVirtualCard")
  favorites           PsychoanalystFavorite[]
  reviews             PsychoanalystReview[]

  healthPlans         PsychoanalystHealthPlan[]
  practiceLocations   PracticeLocation[]        @relation("PsychoanalystLocations")
  services            ProviderService[]         @relation("PsychoanalystServices")
  slotAlerts          SlotAvailabilityAlert[]   @relation("PsychoanalystSlotAlerts")

  @@index([userId])
}

model PsychoanalystAvailabilitySlot {
  id               String              @id @default(cuid())
  psychoanalystId  String
  psychoanalyst    PsychoanalystProfile  @relation(fields: [psychoanalystId], references: [id], onDelete: Cascade)

  dayOfWeek        Int
  startTime        String
  endTime          String
  slotDurationMins Int    @default(50)
  isActive         Boolean @default(true)

  @@index([psychoanalystId])
}

// ─────────────────────────────────────────
// MEDICATIONS (FIX: two separate flows)
// ─────────────────────────────────────────

model Medication {
  id              String         @id @default(cuid())
  patientId       String
  patient         PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  name            String         // @encrypted — PHI
  dosage          String?        // @encrypted — PHI
  frequency       String?        // @encrypted — PHI
  startDate       DateTime?
  endDate         DateTime?
  prescribedBy    String?
  notes           String?        // @encrypted

  // THE FIX: separates clinical from purchase
  flow            MedicationFlow @default(CLINICAL)

  // PURCHASE flow: linked to DrugCatalog + CMED reference at save time
  drugCatalogId       String?
  referencePriceCents Int?

  active          Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([patientId])
  @@index([flow])  // allows querying clinical vs purchase separately
}

// ─────────────────────────────────────────
// APPOINTMENTS + SCHEDULING
// ─────────────────────────────────────────

model AvailabilitySlot {
  id               String              @id @default(cuid())
  professionalId   String
  professional     ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  dayOfWeek        Int    // 0=Sunday, 6=Saturday
  startTime        String // "09:00"
  endTime          String // "17:00"
  slotDurationMins Int    @default(30)
  isActive         Boolean @default(true)

  @@index([professionalId])
}

model Appointment {
  id               String              @id @default(cuid())
  patientId        String
  patient          PatientProfile      @relation(fields: [patientId], references: [id])
  providerType     ProviderType        @default(HEALTH)
  professionalId   String?
  professional     ProfessionalProfile? @relation(fields: [professionalId], references: [id])
  psychoanalystId  String?
  psychoanalyst    PsychoanalystProfile? @relation(fields: [psychoanalystId], references: [id])

  scheduledAt      DateTime
  durationMins     Int                 @default(30)
  type             AppointmentType     @default(TELECONSULT)
  status           AppointmentStatus   @default(PENDING)

  // Teleconsult
  meetingUrl       String?
  meetingRoomId    String?

  // Payment
  priceAmount      Int     // in cents
  currency         String  @default("USD")
  stripePaymentId  String?
  paidAt           DateTime?

  // Clinical
  chiefComplaint   String? // @encrypted — PHI
  notes            String? // @encrypted — PHI

  // Reminders sent
  reminder24hSent  Boolean @default(false)
  reminder1hSent   Boolean @default(false)
  reviewRequestSent Boolean @default(false)

  bookingSource    String?  // patient_panel | public_profile | public_search

  cancelledAt      DateTime?
  cancelledBy      String?
  cancelReason     String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  documents        MedicalDocument[]

  @@index([patientId])
  @@index([professionalId])
  @@index([psychoanalystId])
  @@index([providerType])
  @@index([scheduledAt])
  @@index([status])
}

// ─────────────────────────────────────────
// MEDICAL DOCUMENTS + CARDS
// ─────────────────────────────────────────

model MedicalDocument {
  id               String              @id @default(cuid())
  patientId        String?
  patient          PatientProfile?     @relation(fields: [patientId], references: [id])
  patientRecordId  String?
  patientRecord    PatientRecord?      @relation(fields: [patientRecordId], references: [id])
  professionalId   String?
  professional     ProfessionalProfile? @relation(fields: [professionalId], references: [id])
  psychoanalystId  String?
  psychoanalyst    PsychoanalystProfile? @relation(fields: [psychoanalystId], references: [id])
  analysandRecordId String?
  analysandRecord  AnalysandRecord?    @relation(fields: [analysandRecordId], references: [id])
  appointmentId    String?
  appointment      Appointment?        @relation(fields: [appointmentId], references: [id])

  type             DocumentType
  recordKind       ClinicalRecordKind @default(OTHER)
  categoryId       String?
  category         Category?    @relation(fields: [categoryId], references: [id])
  title            String       // @encrypted
  content          String?      @db.Text  // @encrypted — PHI
  fileUrl          String?      // S3 URL — @encrypted

  // When this record is a COPY of a document shared by a patient (4D/3D-2),
  // this points to the original shared document (to prevent duplicates).
  sourceDocumentId String?

  // Sharing
  sharedRecords    SharedRecord[]

  // Digital signature via Lacuna (same flow as Prescription)
  signatureSessionId String?
  signatureStatus    String?   // PENDING | SIGNED | CANCELLED | ERROR
  signedFileUrl      String?   // S3 key of signed PDF
  signedAt           DateTime?
  digitalSignature   String?
  patientNotifiedAt  DateTime?
  whatsappNotifiedAt DateTime?
  whatsappNotifyStatus String? // SENT | FAILED | NO_PHONE | SKIPPED

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  prescriptions    Prescription[]

  @@index([patientId])
  @@index([patientRecordId])
  @@index([analysandRecordId])
  @@index([psychoanalystId])
  @@index([type])
  @@index([categoryId])
  @@index([recordKind])
}

model SharedRecord {
  id               String           @id @default(cuid())
  documentId       String
  document         MedicalDocument  @relation(fields: [documentId], references: [id])
  patientId        String
  patient          PatientProfile   @relation(fields: [patientId], references: [id])

  // Who can access
  sharedWithEmail  String?   // external share
  sharedWithUserId String?   // internal share

  // Direction of the share (Phase 4D)
  sharedByUserId            String?              // NEW — who shared it (patient, when patient->doctor)
  sharedWithProfessionalId  String?              // NEW — recipient professional (patient->doctor)
  sharedWithProfessional    ProfessionalProfile? @relation("DocsSharedWithProfessional", fields: [sharedWithProfessionalId], references: [id]) // NEW

  accessToken      String    @unique @default(cuid()) // for link sharing
  expiresAt        DateTime? // null = never expires
  viewedAt         DateTime?

  createdAt        DateTime  @default(now())

  @@index([patientId])
  @@index([accessToken])
  @@index([sharedWithProfessionalId])
}

model Prescription {
  id               String              @id @default(cuid())
  documentId       String?
  document         MedicalDocument?    @relation(fields: [documentId], references: [id])
  professionalId   String
  professional     ProfessionalProfile @relation(fields: [professionalId], references: [id])

  // @encrypted — all PHI
  medications      Json    // [{name, dosage, frequency, duration, instructions}]
  instructions     String? // @encrypted
  validUntil       DateTime?
  digitalSignature String? // professional's signature reference (e.g. Lacuna session id)

  // Digital signature via Lacuna Rest PKI Core (cloud certificate / PAdES)
  signatureSessionId String?   // Rest PKI Core signature session id
  signatureStatus    String?   // PENDING | SIGNED | CANCELLED | ERROR
  signedFileUrl      String?   // S3 key of the signed PDF
  signedAt           DateTime?
  patientNotifiedAt  DateTime?
  whatsappNotifiedAt DateTime?
  whatsappNotifyStatus String? // SENT | FAILED | NO_PHONE | SKIPPED

  createdAt        DateTime @default(now())

  @@index([professionalId])
}

// ─────────────────────────────────────────
// MESSAGING
// ─────────────────────────────────────────

model Message {
  id          String   @id @default(cuid())
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId  String
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id])

  content     String   @db.Text  // @encrypted — may contain PHI
  readAt      DateTime?
  deletedAt   DateTime?

  createdAt   DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
}

// ─────────────────────────────────────────
// PAYMENTS + SUBSCRIPTIONS
// ─────────────────────────────────────────

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id])

  stripeCustomerId     String   @unique
  stripeSubscriptionId String?  @unique
  stripePriceId        String?

  status               String   // active, cancelled, past_due, trialing
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean  @default(false)

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ─────────────────────────────────────────
// PROFESSIONAL VIRTUAL CARD
// ─────────────────────────────────────────

model VirtualCard {
  id              String                @id @default(cuid())
  professionalId  String?               @unique
  professional    ProfessionalProfile?  @relation("ProfessionalVirtualCard", fields: [professionalId], references: [id])
  psychoanalystId String?               @unique
  psychoanalyst   PsychoanalystProfile? @relation("PsychoanalystVirtualCard", fields: [psychoanalystId], references: [id])

  slug            String                @unique
  specialtySlug   String                @default("")
  citySlug        String                @default("")
  headline        String?
  website         String?
  googleBusinessUrl String?
  socialLinks     Json?
  isPublic        Boolean               @default(false)

  profileEvents   PublicProfileEvent[]

  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([specialtySlug, citySlug])
}

enum PublicProfileEventType {
  VIEW
  BOOK_CLICK
}

model PublicProfileEvent {
  id            String                 @id @default(cuid())
  virtualCardId String
  virtualCard   VirtualCard            @relation(fields: [virtualCardId], references: [id], onDelete: Cascade)
  type          PublicProfileEventType
  source        String?
  createdAt     DateTime               @default(now())

  @@index([virtualCardId, createdAt])
  @@index([virtualCardId, type, createdAt])
}

// ─────────────────────────────────────────
// HEALTH PLANS (convênios) — public search filter
// ─────────────────────────────────────────

model HealthPlan {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  sortOrder Int      @default(0)

  professionals  ProfessionalHealthPlan[]
  psychoanalysts PsychoanalystHealthPlan[]

  @@index([sortOrder])
}

model ProfessionalHealthPlan {
  professionalId String
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  healthPlanId   String
  healthPlan     HealthPlan          @relation(fields: [healthPlanId], references: [id], onDelete: Cascade)

  allowedWeekdays Int[] @default([]) // empty = all days the provider is open
  minLeadDays     Int   @default(0)  // minimum booking advance (days)

  @@id([professionalId, healthPlanId])
  @@index([healthPlanId])
}

model PsychoanalystHealthPlan {
  psychoanalystId String
  psychoanalyst   PsychoanalystProfile @relation(fields: [psychoanalystId], references: [id], onDelete: Cascade)
  healthPlanId    String
  healthPlan      HealthPlan           @relation(fields: [healthPlanId], references: [id], onDelete: Cascade)

  allowedWeekdays Int[] @default([])
  minLeadDays     Int   @default(0)

  @@id([psychoanalystId, healthPlanId])
  @@index([healthPlanId])
}

// ─────────────────────────────────────────
// PRACTICE LOCATIONS + SERVICES (public profile)
// ─────────────────────────────────────────

model PracticeLocation {
  id              String                @id @default(cuid())
  professionalId  String?
  professional    ProfessionalProfile?  @relation("ProfessionalLocations", fields: [professionalId], references: [id], onDelete: Cascade)
  psychoanalystId String?
  psychoanalyst   PsychoanalystProfile? @relation("PsychoanalystLocations", fields: [psychoanalystId], references: [id], onDelete: Cascade)

  name            String
  address         String
  city            String
  state           String?
  country         String?
  zip             String?
  latitude        Float?
  longitude       Float?
  isPrimary       Boolean  @default(false)
  sortOrder       Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([professionalId])
  @@index([psychoanalystId])
}

model ProviderService {
  id              String                @id @default(cuid())
  professionalId  String?
  professional    ProfessionalProfile?  @relation("ProfessionalServices", fields: [professionalId], references: [id], onDelete: Cascade)
  psychoanalystId String?
  psychoanalyst   PsychoanalystProfile? @relation("PsychoanalystServices", fields: [psychoanalystId], references: [id], onDelete: Cascade)

  name            String
  description     String?
  priceCents      Int?
  currency        String   @default("BRL")
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([professionalId])
  @@index([psychoanalystId])
}

model SlotAvailabilityAlert {
  id              String                @id @default(cuid())
  professionalId  String?
  professional    ProfessionalProfile?  @relation("ProfessionalSlotAlerts", fields: [professionalId], references: [id], onDelete: Cascade)
  psychoanalystId String?
  psychoanalyst   PsychoanalystProfile? @relation("PsychoanalystSlotAlerts", fields: [psychoanalystId], references: [id], onDelete: Cascade)

  email           String
  slug            String
  active          Boolean  @default(true)
  notifiedAt      DateTime?

  createdAt       DateTime @default(now())

  @@unique([email, professionalId])
  @@unique([email, psychoanalystId])
  @@index([slug])
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String
  body      String
  type      String   // appointment_reminder, message, payment, system
  data      Json?
  readAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([readAt])
}

// Patient favorites (map) + optional online alert
model PatientFavorite {
  id             String              @id @default(cuid())
  patientUserId  String
  patientUser    User                @relation("PatientFavorites", fields: [patientUserId], references: [id], onDelete: Cascade)
  professionalId String
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  notifyOnline   Boolean             @default(true)
  createdAt      DateTime            @default(now())

  @@unique([patientUserId, professionalId])
  @@index([professionalId])
}

model PsychoanalystFavorite {
  id              String              @id @default(cuid())
  patientUserId   String
  psychoanalystId String
  psychoanalyst   PsychoanalystProfile  @relation(fields: [psychoanalystId], references: [id], onDelete: Cascade)
  notifyOnline    Boolean             @default(true)
  createdAt       DateTime            @default(now())

  @@unique([patientUserId, psychoanalystId])
  @@index([psychoanalystId])
}

// Patient reviews of professionals (1 per patient per professional)
model ProfessionalReview {
  id             String              @id @default(cuid())
  patientUserId  String
  patientUser    User                @relation("PatientReviews", fields: [patientUserId], references: [id], onDelete: Cascade)
  professionalId String
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  rating         Int                 // 1–5
  comment        String?             @db.Text
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([patientUserId, professionalId])
  @@index([professionalId])
}

model PsychoanalystReview {
  id              String              @id @default(cuid())
  patientUserId   String
  psychoanalystId String
  psychoanalyst   PsychoanalystProfile @relation(fields: [psychoanalystId], references: [id], onDelete: Cascade)
  rating          Int
  comment         String?             @db.Text
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([patientUserId, psychoanalystId])
  @@index([psychoanalystId])
}

// ─────────────────────────────────────────
// COMPLIANCE — HIPAA + GDPR
// ─────────────────────────────────────────

// Every access to PHI must create an audit log — HIPAA requirement
model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  user        User?       @relation(fields: [userId], references: [id])

  action      AuditAction
  resource    String      // e.g. "PatientProfile", "MedicalDocument"
  resourceId  String?
  ipAddress   String?     // @encrypted
  userAgent   String?
  details     Json?       // additional context, never store PHI here

  createdAt   DateTime    @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// Explicit consent tracking — GDPR requirement
model Consent {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        ConsentType
  version     String      // "1.0", "1.1" etc — matches document version
  granted     Boolean
  grantedAt   DateTime    @default(now())
  revokedAt   DateTime?
  ipAddress   String?     // @encrypted
  userAgent   String?

  @@unique([userId, type, version])
  @@index([userId])
}

// GDPR right to data portability + right to erasure
model DataExportRequest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  type        String   // "export" or "deletion"
  status      String   @default("pending") // pending, processing, completed, failed
  fileUrl     String?  // S3 URL of export ZIP (for export requests)
  completedAt DateTime?
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// ────────────────────────────────────────────
// PATIENT RECORD (chart created by a professional)
// A patient "file" the doctor keeps. May or may not be linked
// to a real user account (linkedUserId). Nothing is shared with
// the patient until the doctor explicitly shares it.
// ────────────────────────────────────────────
model PatientRecord {
  id              String   @id @default(cuid())
  professionalId  String
  professional    ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  // Patient data filled by the professional — @encrypted in app layer (PHI)
  firstName       String   // @encrypted
  lastName        String   // @encrypted
  email           String?  // used to link/invite the patient
  phone           String?  // @encrypted
  dateOfBirth     String?   // @encrypted — ISO date string YYYY-MM-DD
  notes           String?  @db.Text // @encrypted — general chart notes
  cpf             String?  // @encrypted — opcional (paciente no exterior pode não ter)
  sex             String?  // opcional — "M", "F", "O" ou livre
  addressLine1    String?  // @encrypted — rua, número, complemento
  city            String?
  state           String?  // estado/província/região
  country         String?  @default("BR")
  zipCode         String?  // @encrypted — CEP / ZIP / código postal

  // Link to a real account, once the patient has one
  linkedUserId    String?
  // Clinical records attached to this chart
  medicalDocuments MedicalDocument[]
  resourceShares   ResourceShare[]
  tags             PatientRecordTag[]
  diagnoses        PatientDiagnosis[]
  metricSnapshots  ClinicalMetricSnapshot[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([professionalId])
  @@index([email])
  @@index([linkedUserId])

}

// ────────────────────────────────────────────
// PHASE 1 — Templates & chart tags
// ────────────────────────────────────────────

model DocumentTemplate {
  id             String       @id @default(cuid())
  professionalId String
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  name           String
  documentType   DocumentType @default(CERTIFICATE)
  title          String
  body           String       @db.Text

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([professionalId])
}

model PrescriptionTemplate {
  id             String   @id @default(cuid())
  professionalId String
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  name           String
  medications    Json
  instructions   String?  @db.Text
  validDays      Int      @default(30)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([professionalId])
}

model PatientRecordTag {
  id              String               @id @default(cuid())
  patientRecordId String
  patientRecord   PatientRecord        @relation(fields: [patientRecordId], references: [id], onDelete: Cascade)

  kind            PatientRecordTagKind
  label           String

  createdAt       DateTime             @default(now())

  @@index([patientRecordId])
}

// ────────────────────────────────────────────
// PHASE 2 — Clinical metrics & diagnoses
// ────────────────────────────────────────────

model PatientDiagnosis {
  id               String          @id @default(cuid())
  patientRecordId  String
  patientRecord    PatientRecord   @relation(fields: [patientRecordId], references: [id], onDelete: Cascade)

  cidCode          String
  cidLabel         String?
  status           DiagnosisStatus @default(ACTIVE)
  notedAt          DateTime        @default(now())
  resolvedAt       DateTime?
  sourceDocumentId String?

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([patientRecordId])
  @@index([patientRecordId, status])
}

model ClinicalMetricSnapshot {
  id              String        @id @default(cuid())
  patientRecordId String
  patientRecord   PatientRecord @relation(fields: [patientRecordId], references: [id], onDelete: Cascade)
  documentId      String?

  recordedAt      DateTime      @default(now())
  weightKg        Float?
  heightCm        Float?
  systolicBp      Int?
  diastolicBp     Int?
  heartRate       Int?
  glucoseMgDl     Float?
  temperatureC    Float?
  spo2Percent     Int?
  bmi             Float?

  createdAt       DateTime      @default(now())

  @@index([patientRecordId, recordedAt])
}

// Analysand chart — separate from medical PatientRecord
model AnalysandRecord {
  id              String   @id @default(cuid())
  psychoanalystId String
  psychoanalyst   PsychoanalystProfile @relation(fields: [psychoanalystId], references: [id], onDelete: Cascade)

  firstName       String   // @encrypted
  lastName        String   // @encrypted
  email           String?
  phone           String?  // @encrypted
  dateOfBirth     String?  // @encrypted
  processStartDate DateTime?
  sessionFrequency String?
  notes           String?  @db.Text // @encrypted

  linkedUserId    String?

  medicalDocuments MedicalDocument[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([psychoanalystId])
  @@index([email])
  @@index([linkedUserId])
}

// ────────────────────────────────────────────
// CATEGORY (dynamic document categories, grouped)
// Managed centrally (admin). Documents point here via categoryId.
// ────────────────────────────────────────────
model Category {
  id          String   @id @default(cuid())
  name        String              // e.g. "Exame de sangue"
  slug        String   @unique     // e.g. "exame-de-sangue"
  groupName   String              // e.g. "Exames"
  groupOrder  Int      @default(0) // order of the group in the menu
  itemOrder   Int      @default(0) // order within the group
  icon        String?             // optional lucide icon name
  isSystem    Boolean  @default(true)  // seeded by the company
  active      Boolean  @default(true)

  // Maps the old enum DocumentType to this category (for migration)
  legacyType  String?             // e.g. "EXAM_RESULT"

  documents   MedicalDocument[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([groupName])
  @@index([slug])
  @@index([active])
}

// ─────────────────────────────────────────
// DRUG CATALOG (medication reference database)
// This is the SEARCHABLE CATALOG of drugs (like Memed's database).
// It is NOT patient data — it's a shared reference list the doctor
// searches when writing a prescription. No PHI here.
// (Note: the existing "Medication" model is the patient's own list —
//  this is different and intentionally named DrugCatalog to avoid collision.)
// ─────────────────────────────────────────
model DrugCatalog {
  id              String   @id @default(cuid())

  // Display + search
  name            String   // commercial/brand name, e.g. "Amoxil"
  activeIngredient String  // e.g. "Amoxicillin" / "Amoxicilina"
  presentation    String   // e.g. "500mg capsule, box of 21"
  manufacturer    String?  // e.g. "GSK"

  // Classification
  country         String   @default("BR")  // "BR", "US", "EU" ...
  category        String?  // e.g. "Antibiotic", "Analgesic"
  controlled      Boolean  @default(false) // tarja preta / controlled substance
  prescriptionType String? // "OTC", "RED_STRIPE", "BLACK_STRIPE", "RX"

  // Normalized lowercase fields for fast case-insensitive search
  searchName      String   // lowercase of name
  searchIngredient String  // lowercase of activeIngredient

  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([searchName])
  @@index([searchIngredient])
  @@index([country])
  @@index([active])

  buyingClub BuyingClub?
}

// ─────────────────────────────────────────
// CBHPM CATALOG (exam / procedure reference — CBHPM 2012)
// Searchable list for exam requests. Not PHI.
// ─────────────────────────────────────────
model CbhpmCatalog {
  id          String   @id @default(cuid())
  code        String   @unique   // e.g. "4.03.01.84-2"
  name        String             // e.g. "Ferro sérico, dosagem"
  chapter     String             // e.g. "4" (diagnostic procedures)
  groupName   String?            // e.g. "BIOQUÍMICA"
  searchName  String             // lowercase normalized name
  searchCode  String             // digits only for partial code search
  edition     String   @default("2012")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([searchName])
  @@index([searchCode])
  @@index([chapter])
  @@index([active])
}

// ─────────────────────────────────────────
// CID-10 CATALOG (Brazilian DATASUS — diagnosis codes)
// Searchable by code (e.g. A010) or description. Not PHI.
// ─────────────────────────────────────────
model Cid10Catalog {
  id                String   @id @default(cuid())
  code              String   @unique   // e.g. "A010" or "M8000/0"
  description       String             // e.g. "Febre tifóide"
  searchDescription String             // lowercase normalized description
  searchCode        String             // uppercase alphanumeric only
  source            String   @default("CID10") // CID10 | CID-O
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([searchDescription])
  @@index([searchCode])
  @@index([active])
  @@index([source])
}

// ─────────────────────────────────────────
// BUYING CLUB — collective medication purchase groups
// One club per DrugCatalog entry. Patients join to get group discounts.
// ─────────────────────────────────────────
model BuyingClub {
  id            String   @id @default(cuid())
  drugCatalogId String   @unique
  drugCatalog   DrugCatalog @relation(fields: [drugCatalogId], references: [id], onDelete: Cascade)
  shareToken    String   @unique @default(cuid())
  status        String   @default("OPEN") // OPEN, READY, CLOSED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  members       BuyingClubMember[]

  @@index([status])
}

model BuyingClubMember {
  id           String     @id @default(cuid())
  buyingClubId String
  buyingClub   BuyingClub @relation(fields: [buyingClubId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  active       Boolean    @default(true)
  joinedAt     DateTime   @default(now())
  leftAt       DateTime?

  @@unique([buyingClubId, userId])
  @@index([buyingClubId, active])
  @@index([userId])
}

model Resource {
  id             String          @id @default(cuid())
  professionalId String
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  title          String          // encrypted
  content        String?         // encrypted — description/notes
  url            String?         // YouTube link (plain — not PHI)
  fileUrl        String?         // encrypted S3 key
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  shares         ResourceShare[]
}

model ResourceShare {
  id              String        @id @default(cuid())
  resourceId      String
  resource        Resource      @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  patientRecordId String
  patientRecord   PatientRecord @relation(fields: [patientRecordId], references: [id], onDelete: Cascade)
  sharedAt        DateTime      @default(now())

  @@unique([resourceId, patientRecordId])
}

// ─────────────────────────────────────────
// JUST-IN-TIME — Plantão Online
// ─────────────────────────────────────────

model JitSession {
  id              String              @id @default(cuid())
  professionalId  String
  professional    ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  mode            JitMode             @default(QUEUE)
  status          JitSessionStatus    @default(OFFLINE)
  specialty       String              // e.g. "Medicina Geral", "Psicologia"

  // Pricing — 0 = gratuito
  priceAmount     Int                 @default(0)  // in cents
  currency        String              @default("BRL")
  isFree          Boolean             @default(true)

  // Queue settings
  maxQueueSize            Int         @default(50)
  estimatedMinutesPerPatient Int      @default(20)
  noShowTimeoutSeconds    Int         @default(120) // 2 minutes

  // Event link (optional — for emergency events like RS floods)
  jitEventId      String?
  jitEvent        JitEvent?           @relation(fields: [jitEventId], references: [id])

  queue           JitQueue[]

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([professionalId])
  @@index([status])
  @@index([specialty])
}

model JitQueue {
  id              String          @id @default(cuid())
  sessionId       String
  session         JitSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Patient — must have account (login required)
  patientUserId   String
  patientUser     User            @relation("JitQueuePatient", fields: [patientUserId], references: [id])

  status          JitQueueStatus  @default(WAITING)
  position        Int             // position in queue (recalculated on each change)
  specialty       String          // what the patient needs

  // Timestamps
  enteredAt       DateTime        @default(now())
  calledAt        DateTime?       // when professional clicked "call next"
  expiresAt       DateTime?       // calledAt + noShowTimeoutSeconds
  startedAt       DateTime?       // when patient clicked "enter"
  endedAt         DateTime?       // when session ended

  // Video room
  meetingUrl      String?         // Daily.co room URL
  meetingRoomId   String?

  // Payment
  paymentId       String?         @unique
  payment         JitPayment?     @relation(fields: [paymentId], references: [id])

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([sessionId])
  @@index([patientUserId])
  @@index([status])
}

model JitPayment {
  id                String    @id @default(cuid())
  amount            Int       // in cents
  currency          String    @default("BRL")
  stripePaymentId   String?   @unique
  paidAt            DateTime?
  status            String    @default("pending") // pending | paid | refunded | failed

  queueEntry        JitQueue?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model JitEvent {
  id          String    @id @default(cuid())
  name        String    // e.g. "Ação RS — Enchentes 2024"
  description String?
  startAt     DateTime
  endAt       DateTime?

  // Force all sessions in this event to be free
  forceFree   Boolean   @default(true)

  // Which specialties are part of this event
  specialties String[]  @default([])

  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  sessions    JitSession[]
}

// ─────────────────────────────────────────
// RATEIO / LIVRO ABERTO (profit-sharing)
// Modelo de "capital aberto sem abrir capital":
// - A comissão (15%) de cada consulta entra no LedgerEntry como COMMISSION_IN.
// - Os custos de máquina (fixos + uso) entram como COST_FIXED / COST_USAGE.
// - Pote do mês = max(0, comissões - custos), por moeda (a moeda que o Stripe processou).
// - O pote é rateado entre profissionais qualificados: base (igual) + mérito (por score).
// Tudo aditivo. Nenhuma tabela existente é alterada (apenas relações novas no
// ProfessionalProfile). PHI nunca entra aqui — só valores e contagens.
// ─────────────────────────────────────────

enum LedgerEntryType {
  COMMISSION_IN   // 15% retido de uma consulta paga (entra no pote)
  COST_FIXED      // assinatura fixa de software (plano Railway, Daily, Resend...)
  COST_USAGE      // custo variável de uso (tokens Anthropic, S3, taxa Stripe, minutos Daily...)
  ADJUSTMENT      // correção manual auditada
}

enum LedgerSource {
  STRIPE_API      // puxado da API do Stripe (nível 2 — fonte verificável)
  AWS_API         // puxado do AWS Cost Explorer (nível 2)
  ANTHROPIC       // console/API Anthropic
  DAILY           // Daily.co
  RAILWAY
  RESEND
  CLOUDFLARE
  MANUAL_INVOICE  // lançado à mão com fatura anexada (nível 1)
  SYSTEM          // calculado internamente (ex.: comissão a partir do próprio banco)
}

enum CostCategory {
  AI_ANTHROPIC
  STORAGE_S3
  PAYMENT_STRIPE
  VIDEO_DAILY
  INFRA_RAILWAY
  EMAIL_RESEND
  CDN_CLOUDFLARE
  OTHER
}

enum PoolPeriodStatus {
  OPEN          // acumulando durante o mês
  CALCULATING   // fechado, calculando contribuições
  LOCKED        // congelado, hash selado, pronto para pagar
  PAID          // rateios pagos
}

// O livro-razão imutável. Cada entrada e saída do balde da comissão é uma linha.
model LedgerEntry {
  id              String           @id @default(cuid())
  type            LedgerEntryType
  category        CostCategory?    // null quando type = COMMISSION_IN
  amountCents     Int              // sempre positivo; o type indica a direção
  currency        String           @default("BRL")
  competenceMonth String           // "2026-06" — mês de competência (a qual pote pertence)

  // Procedência / verificabilidade
  source          LedgerSource
  sourceRef       String?          // id externo (Stripe balance_txn, etc.) OU hash da resposta da API
  invoiceUrl      String?          // chave S3 da fatura tarjada (nível 1)
  fetchedAt       DateTime?        // quando foi puxado da fonte (nível 2)

  // Referência mole à consulta que gerou a comissão (sem FK — ledger não cascateia)
  appointmentId   String?
  jitQueueId      String?

  // Encadeamento por hash — torna o passado impossível de reescrever
  prevHash        String?
  hash            String           @unique

  occurredAt      DateTime         // data do fato no mundo real
  createdAt       DateTime         @default(now())

  poolPeriodId    String?
  poolPeriod      PoolPeriod?      @relation(fields: [poolPeriodId], references: [id])

  @@index([competenceMonth, currency])
  @@index([type])
  @@index([category])
  @@index([poolPeriodId])
}

// O pote de um mês, por moeda. Uma linha por (mês, moeda).
model PoolPeriod {
  id               String           @id @default(cuid())
  month            String           // "2026-06"
  currency         String           @default("BRL")

  commissionCents  Int              @default(0)
  costFixedCents   Int              @default(0)
  costUsageCents   Int              @default(0)
  poolCents        Int              @default(0)   // max(0, commission - (fixed + usage))

  // Parâmetros vigentes (congelados no fechamento — nunca retroativos)
  baseFraction     Float            @default(0.30) // 30% dividido igualmente
  meritFraction    Float            @default(0.70) // 70% por score
  minValidConsults Int              @default(10)    // mínimo para qualificar
  minRating        Float            @default(3.5)   // nota mínima para entrar no pote

  status           PoolPeriodStatus @default(OPEN)
  lockedAt         DateTime?
  ledgerHashAtLock String?          // hash do último lançamento no momento do fechamento
  paidAt           DateTime?

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  entries          LedgerEntry[]
  contributions    PoolContribution[]

  @@unique([month, currency])
  @@index([status])
}

// Quanto cada profissional leva no pote daquele mês.
model PoolContribution {
  id               String              @id @default(cuid())
  poolPeriodId     String
  poolPeriod       PoolPeriod          @relation(fields: [poolPeriodId], references: [id], onDelete: Cascade)
  professionalId   String
  professional     ProfessionalProfile @relation(fields: [professionalId], references: [id])

  validConsults    Int                 @default(0)
  ratingUsed       Float?
  qualityMult      Float               @default(1.0) // multiplicador de qualidade (com piso/teto)
  score            Float               @default(0)    // validConsults * qualityMult

  qualified        Boolean             @default(false)
  disqualReason    String?             // motivo, se não qualificou

  baseCents        Int                 @default(0)
  meritCents       Int                 @default(0)
  totalCents       Int                 @default(0)

  payoutStatus     String              @default("pending") // pending | paid | failed | held
  stripeTransferId String?
  paidAt           DateTime?

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@unique([poolPeriodId, professionalId])
  @@index([professionalId])
  @@index([payoutStatus])
}

// O coração do anti-burla: define se uma consulta conta para o score.
// Referência mole a Appointment OU JitQueue (exatamente um).
model ConsultationValidation {
  id                  String              @id @default(cuid())

  appointmentId       String?             @unique
  jitQueueId          String?             @unique

  professionalId      String
  professional        ProfessionalProfile @relation(fields: [professionalId], references: [id])
  competenceMonth     String              // "2026-06"
  currency            String              @default("BRL")

  // Carimbos objetivos (vindos de sistemas de registro, não auto-declarados)
  paymentSettled      Boolean             @default(false) // Stripe pago e liquidado
  outsideRefundWindow Boolean             @default(false) // fora da janela de estorno
  patientVerified     Boolean             @default(false) // User distinto, e-mail verificado, meio de pagamento não compartilhado
  callConnected       Boolean             @default(false) // chamada realmente conectada
  durationSeconds     Int?                // duração real (Plantão agora; Appointment via webhook Daily depois)
  hasClinicalRecord   Boolean             @default(false) // prontuário/receita criado

  grossCents          Int                 @default(0)     // preço da consulta
  commissionCents     Int                 @default(0)     // 15% congelado aqui

  // Fraude
  fraudFlags          String[]            @default([])
  fraudScore          Float               @default(0)
  underReview         Boolean             @default(false)

  isValid             Boolean             @default(false) // veredito final para o score

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([professionalId, competenceMonth])
  @@index([competenceMonth, currency])
  @@index([isValid])
}
