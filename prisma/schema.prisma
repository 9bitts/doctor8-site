  trainingInstitution String
  certifications  String?
  yearsOfPractice Int      @default(0)
  bio             String?

  clinicName      String?
  clinicAddress   String?
  clinicCity      String?
  clinicState     String?
  clinicCountry   String?
  clinicZip       String?
  clinicLatitude  Float?
  clinicLongitude Float?

  acceptsTeleconsult  Boolean @default(true)
  acceptsInPerson     Boolean @default(false)
  consultPrice        Float
  currency            String  @default("USD")
  sessionDurationMins Int     @default(50)

  availability    Json?

  verified        Boolean  @default(false)
  verifiedAt      DateTime?
  verifiedBy      String?

  acuraVolunteer  Boolean  @default(false)

