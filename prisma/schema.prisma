  @@index([labType])
  @@index([addressCity, addressState])
}

model LaboratoryMember {
  id            String                 @id @default(cuid())
  laboratoryId  String
  laboratory    Laboratory             @relation(fields: [laboratoryId], references: [id], onDelete: Cascade)
  userId        String
  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role          LaboratoryMemberRole
  status        LaboratoryMemberStatus @default(ACTIVE)

  invitedAt     DateTime?
  joinedAt      DateTime               @default(now())

  @@unique([laboratoryId, userId])
  @@index([userId])
  @@index([laboratoryId])
}

model ExamCatalog {
  id         String       @id @default(cuid())
  name       String
  slug       String       @unique
  category   ExamCategory
  code       String?
  searchName String

  exams      LaboratoryExamItem[]

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([category])
  @@index([searchName])
  @@index([code])
}

model LaboratoryExamItem {
  id            String      @id @default(cuid())
  laboratoryId  String
  laboratory    Laboratory  @relation(fields: [laboratoryId], references: [id], onDelete: Cascade)
  examCatalogId String
  examCatalog   ExamCatalog @relation(fields: [examCatalogId], references: [id], onDelete: Restrict)

  priceCents    Int
  available     Boolean     @default(true)
  internalCode  String?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([laboratoryId, examCatalogId])
  @@index([laboratoryId])
  @@index([examCatalogId])
  @@index([laboratoryId, available])
}

model LaboratoryExamImport {
  id               String     @id @default(cuid())
  laboratoryId     String
  laboratory       Laboratory @relation(fields: [laboratoryId], references: [id], onDelete: Cascade)
  filename         String?
  rowsTotal        Int        @default(0)
  rowsMatched      Int        @default(0)
  rowsCreated      Int        @default(0)
  rowsUpdated      Int        @default(0)
  rowsSkipped      Int        @default(0)
  errorsJson       Json?
  importedByUserId String?

  createdAt        DateTime   @default(now())

  @@index([laboratoryId])
}

// ─────────────────────────────────────────
// MEDICINA NATURAL — monografias unificadas (5 práticas PICS)
// Catálogo de referência clínica — sem PHI.
// Chás medicinais → FITOTERAPICO (formaFarmaceutica em detalhesEspecificos).
// ─────────────────────────────────────────

enum CategoriaPraticaMedicinaNatural {
  FITOTERAPICO
  FLORAL
  AROMATERAPIA
  HOMEOPATIA
  APITERAPIA
  CANNABIS
}

enum StatusRegulatorioMedicinaNatural {
  MEDICAMENTO_REGISTRADO
  PRODUTO_TRADICIONAL_NOTIFICADO
  USO_TRADICIONAL_SEM_REGISTRO
  PRATICA_INTEGRATIVA_NAO_REGULADA
  PRODUTO_AUTORIZADO_ANVISA
}

model MedicinaNaturalItem {
  id   String @id @default(cuid())
  slug String @unique

  nome              String
  nomesAlternativos String[] @default([])
  nomeCientifico    String?  @unique

  categoriaPratica CategoriaPraticaMedicinaNatural

  indicacoes               String   @db.Text
  contraindicacoes         String   @db.Text
  precaucoes               String   @db.Text
  interacoesMedicamentosas String?  @db.Text
  posologia                String   @db.Text
  viaAdministracao         String[] @default([])

  statusRegulatorio StatusRegulatorioMedicinaNatural

  /// [{ fonte, edicao, url?, dataConsulta?, campos? }]
  fontes Json @default("[]")

  alertaGestacaoPediatria String? @db.Text

  renisus Boolean @default(false)

  detalhesEspecificos Json @default("{}")

  searchText String

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoriaPratica])
  @@index([categoriaPratica, active])
  @@index([searchText])
  @@index([nomeCientifico])
  @@index([statusRegulatorio])
}

model EmailCampaign {
  id         String   @id @default(cuid())
  name       String
  subject    String
  bodyHtml   String   @db.Text
  status     String   @default("DRAFT") // DRAFT | SENDING | PAUSED | DONE
  batchSize  Int      @default(300)
  lastError  String?  @db.Text
  batchLockAt DateTime?
  scheduledBatchAt DateTime?
  createdBy  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  recipients EmailCampaignRecipient[]
}

model EmailCampaignRecipient {
  id           String        @id @default(cuid())
  campaignId   String
  campaign     EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  email        String
  name         String?
  token        String        @unique @default(cuid())
  status       String        @default("PENDING") // PENDING | SENT | SEND_FAILED | BOUNCED | COMPLAINED | OPTED_OUT | OPENED | CLICKED | REGISTERED
  batchNumber  Int?
  sentAt       DateTime?
  registeredAt DateTime?
  errorMessage String?
  resendEmailId String?
  userId       String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([campaignId, email])
  @@index([campaignId, status])
  @@index([resendEmailId])
}
